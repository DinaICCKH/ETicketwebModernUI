@using System.Globalization
@model ETicketNewUI.Models.RecurringTask
@{
    ViewData["Title"] = "Add Recurring Task";
}

<h5 class="mb-3">Add Recurring Task</h5>

<form asp-action="Create" method="post" id="recurringTaskForm">
    @Html.AntiForgeryToken()
    <div class="row g-2 fs-7">

        <!-- Dates & Frequency Card -->
        <div class="col-12">
            <div class="card shadow-sm rounded-3 p-2">
                <h6 class="fw-bold mb-2 text-primary"><i class="bi bi-calendar2-event me-1"></i>Schedule</h6>
                <div class="row g-2">

                    <!-- From Date -->
                    <div class="col-md-4">
                        <label asp-for="FromDate" class="form-label">From Date</label>
                        <input asp-for="FromDate" class="form-control form-control-sm" id="FromDate" placeholder="Select date" />
                        <span asp-validation-for="FromDate" class="text-danger small"></span>
                    </div>

                    <!-- To Date -->
                    <div class="col-md-4">
                        <label asp-for="ToDate" class="form-label">To Date</label>
                        <input asp-for="ToDate" class="form-control form-control-sm" id="ToDate" placeholder="Select date" />
                        <span asp-validation-for="ToDate" class="text-danger small"></span>
                    </div>

                    <!-- Frequency -->
                    <div class="col-md-4">
                        <label asp-for="Frequency" class="form-label small">Frequency</label>
                        <select asp-for="Frequency" class="form-select form-select-sm" id="frequencySelect">
                            <option value="">--Select--</option>
                            @foreach (var freq in ViewBag.FrequencyList as List<string>)
                            {
                                <option value="@freq">@freq</option>
                            }
                        </select>
                    </div>

                    <!-- Weekly Extra -->
                    <div class="col-md-4" id="weeklyExtras" style="display:none;">
                        <label class="form-label small">Weekly Day</label>
                        <select asp-for="ExecutionDayForWeekly" class="form-select form-select-sm">
                            <option value="">--Day--</option>
                            @foreach (var day in new List<string> { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
                            {
                                <option value="@day">@day</option>
                            }
                        </select>
                    </div>

                    <!-- Monthly Extra -->
                    <div class="col-md-4" id="monthlyExtras" style="display:none;">
                        <label class="form-label small">Monthly Day</label>
                        <select asp-for="ExecutionDayForMonthly" class="form-select form-select-sm">
                            <option value="">--Day--</option>
                            @for (int i = 1; i <= 31; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>


                    <!-- Execution Time (Always Visible) -->
                    <div class="col-md-4">
                        <label asp-for="ExecutionTime" class="form-label small">Execution Time</label>
                        <input asp-for="ExecutionTime" type="text" class="form-control form-control-sm" id="executionTime" placeholder="Select time" />
                        <span asp-validation-for="ExecutionTime" class="text-danger small"></span>
                    </div>

                </div>
            </div>
        </div>

        <!-- Project & Staff Card -->
        <div class="col-12">
            <div class="card shadow-sm rounded-3 p-2">
                <h6 class="fw-bold mb-2 text-primary"><i class="bi bi-people me-1"></i>Assignment</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="ProjectID" class="form-label small">Project</label>
                        <select asp-for="ProjectID" class="form-select form-select-sm">
                            <option value="">--Select Project--</option>
                            @foreach (var project in ViewBag.ProjectList)
                            {
                                <option value="@project.CompanyId">@project.CompanyName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="AssignToUserID" class="form-label small">Assign To</label>
                        <select asp-for="AssignToUserID" class="form-select form-select-sm">
                            <option value="">--Select Staff--</option>
                            @foreach (var staff in ViewBag.StaffList)
                            {
                                <option value="@staff.StaffID">@staff.FullStaffName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="HandleByUserID" class="form-label small">Handle By</label>
                        <select asp-for="HandleByUserID" class="form-select form-select-sm">
                            <option value="">--Select Staff--</option>
                            @foreach (var staff in ViewBag.StaffList)
                            {
                                <option value="@staff.StaffID">@staff.FullStaffName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Deadline" class="form-label small">Deadline (Days)</label>
                        <input asp-for="Deadline" class="form-control form-control-sm" type="number" min="0" />
                    </div>

                </div>
            </div>
        </div>

        <!-- Remark Card -->
        <div class="col-12">
            <div class="card shadow-sm rounded-3 p-2">
                <h6 class="fw-bold mb-2 text-primary"><i class="bi bi-card-text me-1"></i>Remark</h6>
                <div class="mb-2">
                    <label asp-for="Remark" class="form-label small">Remark</label>
                    <textarea asp-for="Remark" class="form-control form-control-sm" rows="2"></textarea>
                </div>
            </div>
        </div>

        <!-- Buttons -->
        <div class="col-12 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-save me-1"></i>Save</button>
        </div>

    </div>
</form>

<!-- jQuery, SweetAlert2, Flatpickr -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            // -------------------- AJAX submit --------------------
            $("#recurringTaskForm").on("submit", function (e) {
                e.preventDefault();
                const formData = new FormData(this);

                $.ajax({
                    url: '@Url.Action("Create", "Recurring")',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        let cleanMessage = (typeof response.message === "string")
                            ? response.message
                            : JSON.stringify(response.message);

                        Swal.fire({
                            icon: response.success ? 'success' : 'error',
                            title: response.success ? 'Success' : 'Error',
                            text: cleanMessage,
                            timer: 2000,
                            timerProgressBar: true,
                            showConfirmButton: false
                        }).then(() => {
                            if (response.success) location.reload();
                        });
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Unexpected error occurred.',
                            confirmButtonText: 'OK'
                        });
                    }
                });
            });

            // -------------------- Flatpickr Init --------------------
            flatpickr("#FromDate", {
                dateFormat: "d-M-Y",
                allowInput: true
            });

            flatpickr("#ToDate", {
                dateFormat: "d-M-Y",
                allowInput: true
            });

            flatpickr("#executionTime", {
                enableTime: true,
                noCalendar: true,
                dateFormat: "H:i",
                time_24hr: true
            });

            // -------------------- Frequency Toggle --------------------
            $("#frequencySelect").on("change", function () {
                const val = $(this).val();
                $("#weeklyExtras").toggle(val === "Weekly");
                $("#monthlyExtras").toggle(val === "Monthly");
            });
        });
    </script>
}
