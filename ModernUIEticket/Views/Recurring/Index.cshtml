@model IEnumerable<ETicketNewUI.Models.RecurringTaskResult>
@using System.Globalization

@{
    ViewData["Title"] = "Recurring Tasks";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
<link href="~/css/listreport.css" rel="stylesheet" />
<link href="~/css/tableresponsiverecurring.css" rel="stylesheet" />
<style>
    #tablePagination {
        font-size: 0.7rem !important;
    }
    #tablePagination .page-item {
        margin: 0 2px;
    }
    #tablePagination .page-link {
        padding: 0.25rem 0.4rem !important;
        font-size: 0.7rem !important;
    }
</style>

<div class="container mt-4" style="min-width:80% !important">
    <div class="card shadow-lg border-0">
        <div class="card shadow-sm">
            <!-- Card Header -->
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" style="background-color:#0099CC !important">
                <h6 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i> Recurring Tasks</h6>
                <div class="d-flex align-items-center gap-2">
                    <!-- Toggle Filters Button -->
                    <button class="btn btn-light btn-sm d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#filterSection" aria-expanded="false" aria-controls="filterSection">
                        <i class="bi bi-filter me-1"></i> Filters
                    </button>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="card-body py-3" style="background-color:aliceblue">
                <div class="collapse" id="filterSection">
                    <form asp-controller="Recurring" asp-action="Index" method="get" class="row g-2 mb-3 align-items-end">

                        <!-- Frequency -->
                        <div class="col-md-2">
                            <label class="form-label small">Frequency</label>
                            <select name="frequency" class="form-select form-select-sm">
                                <option value="ALL">All</option>
                                <option value="Daily">Daily</option>
                                <option value="Weekly">Weekly</option>
                                <option value="Monthly">Monthly</option>
                                <option value="Yearly">Yearly</option>
                            </select>
                        </div>

                        <!-- Status -->
                        <div class="col-md-2">
                            <label class="form-label small">Status</label>
                            <select name="status" class="form-select form-select-sm">
                                <option value="ALL">All</option>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <button type="submit" class="btn btn-sm btn-primary w-100">
                                <i class="bi bi-search me-1"></i> Search
                            </button>
                        </div>

                        <!-- Global Search -->
                        <div class="col-md-5 d-flex align-items-end">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                                <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Find anything in table..." />
                            </div>
                        </div>

                        <!-- Export -->
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="button" class="btn btn-sm btn-success w-100" id="exportExcel">
                                <i class="bi bi-file-earmark-excel me-1"></i> Export
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>

        <!-- Table -->
        <div class="card-body p-0">
            <div class="table-responsive p-3" id="taskTableContainer">
                <table class="table table-hover table-sm-font align-middle mb-0" id="taskTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:4%;">No</th>
                            <th style="width:5%;">Task ID</th>
                            <th style="width:12%;">Company</th>
                            <th style="width:12%;">Assign To</th>
                            <th style="width:12%;">Handle By</th>
                            <th style="width:8%;">Frequency</th>
                            <th style="width:8%;">Exec Time</th>
                            <th style="width:8%;">Status</th>
                            <th style="width:10%;">Created Date</th>
                            <th style="width:20%;">Remark</th>
                            <th style="width:5%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 1;
                        }
                        @foreach (var task in Model)
                        {
                            <tr data-id="@task.TaskID">
                                <td><span>@rowIndex</span></td>
                                <td><span>@task.TaskID</span></td>
                                <td><span>@task.CompanyName</span></td>
                                <td><span>@task.AssignToUserName</span></td>
                                <td><span>@task.HandleByUserName</span></td>
                                <td><span>@task.Frequency</span></td>
                                <td><span>@task.ExecutionTime</span></td>
                                <td>
                                    <span class="badge" style="background-color:@(task.Status == "Active" ? "green" : "red"); color:white;">
                                        <span>@task.Status</span>
                                    </span>
                                </td>
                                <td><span>@task.CreatedDate.ToString("dd-MMM-yyyy")</span></td>
                                <td><span>@task.Remark</span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary rounded-circle btn-actions" data-id="@task.TaskID" title="Actions">
                                        <i class="bi bi-gear"></i>
                                    </button>
                                </td>
                            </tr>
                            rowIndex++;
                        }
                    </tbody>
                </table>
            </div>
        </div>


        <ul class="pagination" id="tablePagination"></ul>
    </div>
</div>

<!-- Action Popups -->
@foreach (var task in Model)
{
    <div id="popup-@task.TaskID" class="action-popup p-2 shadow rounded bg-white border">
        <ul class="list-unstyled mb-0">
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                   href="@Url.Action("Edit", "Recurring", new { id = task.TaskID })">
                    <i class="bi bi-pencil-square me-2 text-primary"></i> Edit
                </a>
            </li>
            <li>
                <a href="javascript:void(0);"
                   class="btn btn-sm btn-light w-100 text-start d-flex align-items-center text-danger delete-task"
                   data-id="@task.TaskID">
                    <i class="bi bi-trash me-2"></i> Delete
                </a>
            </li>


        </ul>
    </div>
}


<div class="toast-container"></div>

@section Scripts {


    <script>

        document.addEventListener("DOMContentLoaded", function () {

            // handle delete clicks (delegated to support dynamic content)
            $(document).on('click', '.delete-task', function (e) {
                e.preventDefault();

                const taskId = $(this).data('id');

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This task will be permanently deleted!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (!result.isConfirmed) return;

                    // Read antiforgery token from the page (rendered by @Html.AntiForgeryToken())
                    const antiToken = $('input[name="__RequestVerificationToken"]').first().val();

                    $.ajax({
                        url: '@Url.Action("Delete", "Recurring")', // controller Delete POST
                        type: 'POST',
                        data: {
                            id: taskId,
                            __RequestVerificationToken: antiToken // include token (if required)
                        },
                        success: function (resp) {
                            if (resp && resp.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Deleted',
                                    text: resp.message || 'Task deleted.',
                                    timer: 1400,
                                    showConfirmButton: false
                                }).then(() => {
                                    // remove row from table or reload page
                                    // Option A: reload page
                                    location.reload();

                                    // Option B: remove row from DOM without reload:
                                    // $(`tr[data-id="${taskId}"]`).remove();
                                });
                            } else {
                                Swal.fire('Error', resp?.message || 'Could not delete task.', 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error', 'Unexpected error occurred.', 'error');
                        }
                    });
                });
            });

        });


        document.addEventListener("DOMContentLoaded", function () {
            const rowsPerPage = 10;
            const table = document.getElementById("taskTable");
            const tbody = table?.querySelector("tbody");
            if (tbody) {
                let rows = Array.from(tbody.querySelectorAll("tr"));
                const pagination = document.getElementById("tablePagination");
                let currentPage = 1;
                let filteredRows = [...rows];

                function renderTablePage(page, displayRows = filteredRows) {
                    const totalPages = Math.ceil(displayRows.length / rowsPerPage);
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    rows.forEach(r => r.style.display = "none");
                    displayRows.forEach((r, i) => { if (i >= start && i < end) r.style.display = ""; });
                    if (pagination) renderPagination(page, totalPages, displayRows);
                }

                function renderPagination(page, totalPages, displayRows) {
                    pagination.innerHTML = "";
                    const createPageItem = (label, disabled, callback) => {
                        const li = document.createElement("li");
                        li.className = "page-item" + (disabled ? " disabled" : "");
                        li.innerHTML = `<a class="page-link" href="#">${label}</a>`;
                        li.addEventListener("click", e => { e.preventDefault(); if (!disabled) callback(); });
                        return li;
                    };
                    pagination.appendChild(createPageItem("Previous", page === 1, () => { currentPage--; renderTablePage(currentPage, displayRows); }));
                    for (let i = 1; i <= totalPages; i++) {
                        const li = createPageItem(i, false, () => { currentPage = i; renderTablePage(currentPage, displayRows); });
                        if (i === page) li.classList.add("active");
                        pagination.appendChild(li);
                    }
                    pagination.appendChild(createPageItem("Next", page === totalPages, () => { currentPage++; renderTablePage(currentPage, displayRows); }));
                }

                const searchInput = document.getElementById("globalSearch");
                searchInput.addEventListener("input", function () {
                    const keyword = this.value.toLowerCase();
                    filteredRows = rows.filter(r => r.innerText.toLowerCase().includes(keyword));
                    currentPage = 1;
                    renderTablePage(currentPage, filteredRows);
                });

                renderTablePage(currentPage, filteredRows);
            }

            document.getElementById("exportExcel").addEventListener("click", function () {
                const tableEl = document.getElementById("taskTable");
                const wb = XLSX.utils.table_to_book(tableEl, { sheet: "RecurringTasks" });
                XLSX.writeFile(wb, `RecurringTasks_${new Date().toISOString().slice(0, 10)}.xlsx`);
            });

            const actionButtons = document.querySelectorAll(".btn-actions");
            actionButtons.forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const id = this.dataset.id;
                    const popup = document.getElementById("popup-" + id);
                    if (popup.style.display === "block") {
                        popup.style.display = "none";
                    } else {
                        document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
                        popup.style.display = "block";
                        const rect = this.getBoundingClientRect();
                        popup.style.position = "absolute";
                        popup.style.top = rect.bottom + window.scrollY + "px";
                        popup.style.left = rect.left + window.scrollX + "px";
                    }
                });
            });

            document.addEventListener("click", function () {
                document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
            });
        });
    </script>
}
