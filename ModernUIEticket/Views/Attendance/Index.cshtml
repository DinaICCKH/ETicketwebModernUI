@model IEnumerable<ETicketNewUI.Models.AttendanceHeaderResult>

@using System.Globalization
@{
    ViewData["Title"] = "Attendance Sessions";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<link href="~/css/listreport.css" rel="stylesheet" />
<link href="~/css/tableresponsiveattendace.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" style="background-color:#0099CC !important">
            <h6 class="mb-0"><i class="bi bi-people-fill me-2"></i> Attendance Sessions</h6>
            <a asp-action="Create" class="btn btn-light btn-sm"><i class="bi bi-plus-circle me-1"></i> Create New Session</a>
        </div>

        <!-- Filter Section -->
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 mb-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Status</label>
                    <select id="filterStatus" name="status" class="form-select form-select-sm">
                        <option value="">-- All --</option>
                        <option value="Planned">Planned</option>
                        <option value="Ongoing">Ongoing</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small mb-1">From</label>
                    <div class="input-group input-group-sm" id="dateFromPicker" data-td-target-input="nearest" data-td-target-toggle="nearest">
                        <input type="text" name="dateFrom" class="form-control form-control-sm" data-td-target="#dateFromPicker"
                               value="@(ViewData["dateFrom"] ?? "")" placeholder="dd-MMM-yyyy" />
                        <span class="input-group-text" data-td-toggle="datetimepicker" data-td-target="#dateFromPicker">
                            <i class="bi bi-calendar"></i>
                        </span>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">To</label>
                    <div class="input-group input-group-sm" id="dateToPicker" data-td-target-input="nearest" data-td-target-toggle="nearest">
                        <input type="text" name="dateTo" class="form-control form-control-sm" data-td-target="#dateToPicker"
                               value="@(ViewData["dateTo"] ?? "")" placeholder="dd-MMM-yyyy" />
                        <span class="input-group-text" data-td-toggle="datetimepicker" data-td-target="#dateToPicker">
                            <i class="bi bi-calendar"></i>
                        </span>
                    </div>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="card-body p-0">
            <div class="table-responsive p-3" id="sessionTableContainer">
                <table class="table table-hover table-sm-font align-middle mb-0" id="sessionTable">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Company</th>
                            <th>Training Date</th>
                            <th>Start / End</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th>Remark</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model)
                        {
                            <tr data-id="@session.AttendanceID" data-status="@session.Status">
                                <td data-label="ID"><span class="value">@session.AttendanceID</span></td>
                                <td data-label="Company"><span class="value">@session.CompanyName</span></td>
                                <td data-label="Training Date"><span class="value">@session.TrainingDate</span></td>
                                <td data-label="Start / End"><span class="value">@session.StartDateTime - @session.EndDateTime</span></td>
                                <td data-label="Status">
                                    <span class="badge value @(session.Status=="Active"?"bg-success": session.Status=="Planned"?"bg-info": session.Status=="Ongoing"?"bg-warning":"bg-danger")">
                                        @session.Status
                                    </span>
                                </td>
                                <td data-label="Created By"><span class="value">@session.UserName</span></td>
                                <td data-label="Remark"><span class="value">@session.Remark</span></td>
                                <td data-label="Action">
                                    <button class="btn btn-sm btn-outline-primary rounded-circle btn-actions" data-id="@session.AttendanceID" title="Actions">
                                        <i class="bi bi-gear"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <ul class="pagination" id="tablePagination"></ul>
        </div>

    </div>
</div>

<!-- Action Popups -->
@foreach (var session in Model)
{
    <div id="popup-@session.AttendanceID" class="action-popup p-2 shadow rounded bg-white border">
        <ul class="list-unstyled mb-0">
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                   href="/Eticket/Attendance/CheckIn?DocEntry=@(session.AttendanceID.ToString()
                                           + session.CreatedBy.ToString()
                                           + session.ProjectID.ToString()
                                           + session.Status.ToString()
                                           + session.Latitude.ToString()
                                           + session.Longitude.ToString()
                                          )"
                   target="_blank">
                    <i class="bi bi-box-arrow-in-right me-2 text-success"></i> Check In
                </a>
            </li>
            <li class="mb-1">
                <button class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                        onclick="copyAndDownload('@session.QrCodeLink','@session.QrCodeImagePath')">
                    <i class="bi bi-clipboard me-2 text-primary"></i> Link&QR
                </button>
            </li>
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                   href="/Eticket/Attendance/Edit/@session.AttendanceID">
                    <i class="bi bi-pencil-square me-2 text-warning"></i> Edit
                </a>
            </li>
            <li>
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center text-danger"
                   href="@Url.Action("Delete", "Attendance", new { id = @session.AttendanceID })"
                   onclick="return confirm('Are you sure you want to delete this session and all its participants?');">
                    <i class="bi bi-trash me-2"></i> Delete
                </a>
            </li>
        </ul>
    </div>
}

<div class="toast-container"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Set selected filter
            var selectedStatus = '@(ViewData["status"] ?? "")';
            if (selectedStatus) document.getElementById("filterStatus").value = selectedStatus;

            // Tempus Dominus datepickers
            new tempusDominus.TempusDominus(document.getElementById('dateFromPicker'), {
                display: { components: { calendar: true, clock: false } }, useCurrent: false, localization: { format: 'dd-MMM-yyyy' }
            });
            new tempusDominus.TempusDominus(document.getElementById('dateToPicker'), {
                display: { components: { calendar: true, clock: false } }, useCurrent: false, localization: { format: 'dd-MMM-yyyy' }
            });

            // Action popup
            document.querySelectorAll('.btn-actions').forEach(btn => {
                btn.addEventListener('click', e => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    const popup = document.getElementById(`popup-${id}`);
                    document.querySelectorAll('.action-popup').forEach(p => { if (p !== popup) p.style.display = 'none'; });
                    const rect = btn.getBoundingClientRect();
                    const popupHeight = popup.offsetHeight;
                    const top = (rect.bottom + popupHeight > window.innerHeight) ? rect.top - popupHeight - 5 : rect.bottom + 5;
                    popup.style.top = `${top}px`;
                    popup.style.left = `${rect.left}px`;
                    popup.style.display = 'block';
                });
            });
            document.addEventListener('click', () => document.querySelectorAll('.action-popup').forEach(p => p.style.display = 'none'));

            // Copy & Download QR
            window.copyAndDownload = function (link, imgPath) {
                navigator.clipboard.writeText(link).then(() => showToast("QR link copied!"));
                if (imgPath) {
                    const a = document.createElement('a'); a.href = imgPath; a.download = imgPath.split('/').pop();
                    document.body.appendChild(a); a.click(); document.body.removeChild(a);
                }
            }

            // Toast
            function showToast(msg) {
                const container = document.querySelector('.toast-container');
                const toast = document.createElement('div');
                toast.className = 'toast align-items-center text-white bg-success border-0 mb-2';
                toast.role = 'alert'; toast.ariaLive = 'assertive'; toast.ariaAtomic = 'true';
                toast.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
                container.appendChild(toast);
                new bootstrap.Toast(toast, { delay: 3000 }).show();
                toast.addEventListener('hidden.bs.toast', () => toast.remove());
            }

            // ------------------- Pagination -------------------
            const rowsPerPage = 10;
            const table = document.getElementById("sessionTable");
            const tbody = table.querySelector("tbody");
            const rows = Array.from(tbody.querySelectorAll("tr"));
            const pagination = document.getElementById("tablePagination");
            let currentPage = 1;
            const totalPages = Math.ceil(rows.length / rowsPerPage);
            const maxVisiblePages = 5; // display only 5 pages at a time

            function renderTablePage(page) {
                const start = (page - 1) * rowsPerPage;
                const end = start + rowsPerPage;
                rows.forEach((row, index) => row.style.display = (index >= start && index < end) ? "" : "none");
                renderPagination(page);
            }

            function renderPagination(page) {
                pagination.innerHTML = "";

                // Previous button
                const prev = document.createElement("li");
                prev.className = "page-item" + (page === 1 ? " disabled" : "");
                prev.innerHTML = `<a class="page-link btn-sm">Prev</a>`;
                prev.addEventListener("click", () => { if (currentPage > 1) { currentPage--; renderTablePage(currentPage); } });
                pagination.appendChild(prev);

                // Calculate visible pages
                let startPage = Math.max(1, page - Math.floor(maxVisiblePages / 2));
                let endPage = startPage + maxVisiblePages - 1;
                if (endPage > totalPages) {
                    endPage = totalPages;
                    startPage = Math.max(1, endPage - maxVisiblePages + 1);
                }

                // Page numbers
                for (let i = startPage; i <= endPage; i++) {
                    const li = document.createElement("li");
                    li.className = "page-item" + (i === page ? " active" : "");
                    li.innerHTML = `<a class="page-link btn-sm">${i}</a>`;
                    li.addEventListener("click", () => { currentPage = i; renderTablePage(currentPage); });
                    pagination.appendChild(li);
                }

                // Next button
                const next = document.createElement("li");
                next.className = "page-item" + (page === totalPages ? " disabled" : "");
                next.innerHTML = `<a class="page-link btn-sm">Next</a>`;
                next.addEventListener("click", () => { if (currentPage < totalPages) { currentPage++; renderTablePage(currentPage); } });
                pagination.appendChild(next);
            }

            renderTablePage(currentPage);
        });
    </script>
}

