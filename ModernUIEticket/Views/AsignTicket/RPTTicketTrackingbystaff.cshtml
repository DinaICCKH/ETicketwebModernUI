@model IEnumerable<ETicketNewUI.Models.TaskTrackingByStaffSummaryDto>
@using System.Globalization
@{
    ViewData["Title"] = "Task Tracking Summary";
}

<style>
    .staff-card {
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        font-size: 0.8rem;
        background: #fff;
        border: 1px solid #e5e5e5;
    }

        .staff-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        }

    .staff-header {
        background: linear-gradient(135deg, #f5f5f5, #ffffff);
        color: #333;
        font-weight: 600;
        padding: 0.45rem 0.7rem;
        font-size: 0.85rem;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .staff-pos {
        font-size: 0.75rem;
        color: #0d6efd;
        font-weight: 500;
        margin-left: 0.4rem;
    }

    .staff-body {
        padding: 0.6rem 0.7rem;
    }

    .status-row {
        display: flex;
        justify-content: space-between;
        padding: 0.15rem 0;
        font-size: 0.75rem;
    }

    .status-label {
        color: #555;
    }

    .badge-modern {
        border-radius: 50px;
        font-size: 0.7rem;
        padding: 0.15rem 0.5rem;
        background: #f8f9fa;
        color: #333;
        border: 1px solid #ddd;
        min-width: 30px;
        text-align: center;
        cursor: pointer;
    }

        .badge-modern.total {
            background: #e9ecef;
            font-weight: 600;
        }
</style>

<div class="container mt-4">

    <!-- Filter Card -->
    <div class="card shadow-sm p-3 mb-4" style="background-color:#f8f9fa; border-radius:10px;">
        <h6 class="fw-bold mb-3">
            <i class="bi bi-journal-text me-2 text-primary"></i> Task Tracking Detail By Staff
        </h6>

        <!-- Date & Status Filters -->
        <div class="row g-3 mb-3">
            <div class="col-md-4 col-sm-12">
                <label for="fromDateFilter" class="form-label">
                    <i class="bi bi-calendar-date me-1 text-secondary"></i> From Date:
                </label>
                <input type="text" id="fromDateFilter" name="fromDateFilter" class="form-control date-picker" placeholder="dd-MMM-yy" required />
            </div>
            <div class="col-md-4 col-sm-12">
                <label for="toDateFilter" class="form-label">
                    <i class="bi bi-calendar2-week me-1 text-secondary"></i> To Date:
                </label>
                <input type="text" id="toDateFilter" name="toDateFilter" class="form-control date-picker" placeholder="dd-MMM-yy" required />
            </div>
            <div class="col-md-4 col-sm-12">
                <label class="form-label">
                    <i class="bi bi-flag me-1 text-secondary"></i> Status:
                </label>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" id="statusDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-check2-square me-1"></i> Select Status
                    </button>
                    <ul class="dropdown-menu p-3" aria-labelledby="statusDropdownBtn" style="max-height: 220px; overflow-y: auto;">
                        @foreach (var status in new string[] { "All", "Request", "Pending", "Reject", "Progress", "Checking", "FeedBack", "Done", "Cancel" })
                        {
                            var statusId = "status" + status.Replace(" ", "");
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-checkbox" type="checkbox" value="@status" id="@statusId">
                                    <label class="form-check-label" for="@statusId">@status</label>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Staff, Assign, Company Filters -->
        <div class="row g-3 mb-3">
            <div class="col-md-4 col-sm-12">
                <label for="MStaffDropdown" class="form-label">
                    <i class="bi bi-person-badge me-1 text-secondary"></i> Staff:
                </label>
                <select id="MStaffDropdown" class="form-select">
                    <option value="All">All</option>
                    @if (ViewBag.Staff != null)
                    {
                        foreach (var module in ViewBag.Staff)
                        {
                            <option value="@module.ID">@module.FullStaffName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-sm-12">
                <label for="MAssignbyDropdown" class="form-label">
                    <i class="bi bi-person-workspace me-1 text-secondary"></i> Assign By:
                </label>
                <select id="MAssignbyDropdown" class="form-select">
                    <option value="All">All</option>
                    @if (ViewBag.Staff != null)
                    {
                        foreach (var module in ViewBag.Staff)
                        {
                            <option value="@module.ID">@module.FullStaffName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-sm-12">
                <label for="MbranchDropdown" class="form-label">
                    <i class="bi bi-building me-1 text-secondary"></i> Company:
                </label>
                <select id="MbranchDropdown" class="form-select">
                    <option value="All">All</option>
                    @if (ViewBag.Branch != null)
                    {
                        foreach (var module in ViewBag.Branch)
                        {
                            <option value="@module.CompanyId">@module.CompanyName</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Report Options -->
        <div class="d-flex justify-content-end">
            <div class="dropdown">
                <button class="btn btn-primary dropdown-toggle px-4" type="button" id="reportDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="background-color:#0099CC;">
                    <i class="bi bi-file-earmark-bar-graph me-1"></i> Report Options
                </button>
                <ul class="dropdown-menu shadow" aria-labelledby="reportDropdown">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="previewReport()"><i class="bi bi-eye me-2 text-info"></i> Preview</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="exportReport('PDF')"><i class="bi bi-file-pdf me-2 text-danger"></i> Print to PDF</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="exportReport('EXCELOPENXML')"><i class="bi bi-file-earmark-excel me-2 text-success"></i> Export to Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="exportReport('WORDOPENXML')"><i class="bi bi-file-earmark-word me-2 text-primary"></i> Export to Word</a></li>
                </ul>
            </div>
        </div>
    </div>


    
    <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-3">
        <!-- Title -->
        <h5 class="fw-bold text-dark mb-0 me-4 flex-shrink-0">
            <i class="bi bi-clipboard-data me-2"></i> Task Tracking Summary
        </h5>

        <!-- Compact From & To Date Filters -->
        <div class="d-flex gap-2 align-items-end flex-wrap" style="font-size:0.8rem;">
            <div style="flex: 1 1 auto; min-width: 120px;">
                <label for="fromDatesummary" class="form-label fw-semibold mb-1 text-secondary" style="font-size:0.75rem;">
                    <i class="bi bi-calendar-date me-1"></i> From
                </label>
                <input type="text" id="fromDatesummary" name="fromDatesummary"
                       class="form-control form-control-sm shadow-sm date-picker"
                       placeholder="dd-MMM-yy"
                       value="@ViewBag.FromDate" />
            </div>

            <div style="flex: 1 1 auto; min-width: 120px;">
                <label for="toDatesummary" class="form-label fw-semibold mb-1 text-secondary" style="font-size:0.75rem;">
                    <i class="bi bi-calendar-date-fill me-1"></i> To
                </label>
                <input type="text" id="toDatesummary" name="toDatesummary"
                       class="form-control form-control-sm shadow-sm date-picker"
                       placeholder="dd-MMM-yy"
                       value="@ViewBag.ToDate" />
            </div>


            <div style="align-self: flex-end;">
                <button type="button" class="btn btn-gradient btn-sm shadow-sm py-1 px-3" onclick="filterTickets()">
                    <i class="bi bi-search me-1"></i> Filter
                </button>
            </div>

        </div>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center border">
            <i class="bi bi-exclamation-triangle me-2 text-warning"></i> No task summary found for this user.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var user in Model)
            {
                <div class="col-12 col-sm-6 col-md-3">
                    <div class="card shadow-sm rounded-3" style="background: #fff; border: none;">
                        <!-- Card Header -->
                        <div class="card-header d-flex justify-content-between align-items-center px-3 py-2"
                             style="background: #f8f9fa; border-bottom: 1px solid #e0e0e0;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span class="fw-semibold">@user.AssignToName</span>
                            </div>
                            <a href="#" class="text-primary fw-semibold text-decoration-none">@user.Position</a>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body p-2">
                            @{
                                var staffStatuses = new List<(string Key, int Value)>
                    {
                    ("Pending", user.Pending),
                    ("Progress", user.Progress),
                    ("Checking", user.Checking),
                    ("Feedback", user.Feedback),
                    ("Done", user.Done),
                    ("Total", user.Total)
                    };
                            }

                            @foreach (var status in staffStatuses)
                            {
                                var link = Url.Action("ExportWorkingStatusReportByStaff", "Report", new
                                {
                                    reportName = "WorkingStatusReportByStaff",
                                    fromDate = ViewBag.FromDate,
                                    toDate = ViewBag.ToDate,
                                    staffId = user.AssignTo,
                                    assignBy = "All",
                                    company = "All",
                                    status = status.Key,
                                    format = "PDF",
                                    inline = true
                                });

                                <div class="d-flex justify-content-between align-items-center py-1 px-2 mb-1 rounded"
                                     style="background: #f0f0f0;">
                                    <!-- changed to gray -->
                                    <span class="text-dark">@status.Key</span>
                                    <a href="@link" target="_blank"
                                       class="badge rounded-pill text-dark fw-bold px-3 py-1"
                                       style="background-color: #ffffff;">
                                        @status.Value <i class="bi bi-arrow-right ms-1" style="color: #FFD700;"></i> <!-- arrow yellow -->
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

        function filterTickets() {
            const fromDate = document.getElementById("fromDatesummary").value;
            const toDate = document.getElementById("toDatesummary").value;

            const url = `/Eticket/AsignTicket/RPTTicketTrackingbystaff?fromDatesummary=${encodeURIComponent(fromDate)}&toDatesummary=${encodeURIComponent(toDate)}`;
            window.location.href = url; // reload page with params
        }

        // --- Status Checkbox Logic ---
        function getSelectedStatusesCSV() {
            const selected = Array.from(document.querySelectorAll('.status-checkbox:checked'))
                .map(cb => cb.value);
            return selected.join(',');
        }

        const statusDropdownBtn = document.getElementById('statusDropdownBtn');
        const statusCheckboxes = document.querySelectorAll('.status-checkbox');

        statusCheckboxes.forEach(cb => {
            cb.addEventListener('change', () => {
                const selected = Array.from(document.querySelectorAll('.status-checkbox:checked'))
                    .map(cb => cb.value);

                if (selected.includes("All")) {
                    statusCheckboxes.forEach(c => {
                        if (c.value !== "All") c.checked = false;
                    });
                    statusDropdownBtn.textContent = "All";
                } else if (selected.length === 0) {
                    statusDropdownBtn.textContent = "Select Status";
                } else {
                    statusDropdownBtn.textContent = selected.join(', ');
                }
            });
        });

        // --- Set Default Dates ---
        $(document).ready(function () {
            $('#fromDateFilter').val("01-Jan-2024");

            const today = new Date();
            const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            const formattedDate = String(today.getDate()).padStart(2, '0') + '-' +
                monthNames[today.getMonth()] + '-' +
                today.getFullYear();

            $('#toDateFilter').val(formattedDate);
        });

        // --- Tempus Dominus Datepickers ---
        new tempusDominus.TempusDominus(document.getElementById('fromDateFilter'), {
            display: { components: { calendar: true, clock: false } },
            useCurrent: false,
            localization: { format: 'dd-MMM-yyyy' }
        });
        new tempusDominus.TempusDominus(document.getElementById('toDateFilter'), {
            display: { components: { calendar: true, clock: false } },
            useCurrent: false,
            localization: { format: 'dd-MMM-yyyy' }
        });

         // --- Tempus Dominus Datepickers ---
        new tempusDominus.TempusDominus(document.getElementById('fromDatesummary'), {
            display: { components: { calendar: true, clock: false } },
            useCurrent: false,
            localization: { format: 'dd-MMM-yyyy' }
        });
        new tempusDominus.TempusDominus(document.getElementById('toDatesummary'), {
            display: { components: { calendar: true, clock: false } },
            useCurrent: false,
            localization: { format: 'dd-MMM-yyyy' }
        });

        // --- Preview Report ---
        function previewReport() {
            const fromDate = $('#fromDateFilter').val();
            const toDate = $('#toDateFilter').val();
            const statusCSV = getSelectedStatusesCSV();
            const staffId = $('#MStaffDropdown').val() || 'All';
            const assignBy = $('#MAssignbyDropdown').val() || 'All';
            const company = $('#MbranchDropdown').val() || 'All';

            const url = `/Eticket/Report/ExportWorkingStatusReportByStaff?reportName=WorkingStatusReportByStaff&fromDate=${encodeURIComponent(fromDate)}&toDate=${encodeURIComponent(toDate)}&staffId=${encodeURIComponent(staffId)}&assignBy=${encodeURIComponent(assignBy)}&company=${encodeURIComponent(company)}&status=${encodeURIComponent(statusCSV)}&format=PDF&inline=true`;

            window.open(url, '_blank');
        }

        // --- Export Report ---
        function exportReport(format) {
            const fromDate = $('#fromDateFilter').val();
            const toDate = $('#toDateFilter').val();
            const statusCSV = getSelectedStatusesCSV();
            const staffId = $('#MStaffDropdown').val() || 'All';
            const assignBy = $('#MAssignbyDropdown').val() || 'All';
            const company = $('#MbranchDropdown').val() || 'All';

            const url = `/Eticket/Report/ExportWorkingStatusReportByStaff?reportName=WorkingStatusReportByStaff&fromDate=${encodeURIComponent(fromDate)}&toDate=${encodeURIComponent(toDate)}&staffId=${encodeURIComponent(staffId)}&assignBy=${encodeURIComponent(assignBy)}&company=${encodeURIComponent(company)}&status=${encodeURIComponent(statusCSV)}&format=${encodeURIComponent(format)}&inline=false`;

            window.open(url, '_blank');
        }

    </script>
}