@model IEnumerable<ETicketNewUI.Models.TicketAssignListDto>

@using System.Globalization
@{
    ViewData["Title"] = "Ticket Assign";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
<link href="~/css/listreport.css" rel="stylesheet" />
<link href="~/css/tableresponsiveindexticketassign.css" rel="stylesheet" />

<style>
    #tablePagination {
        font-size: 0.7rem !important; /* smaller font */
    }

        #tablePagination .page-item {
            margin: 0 2px; /* optional, reduce spacing */
        }

        #tablePagination .page-link {
            padding: 0.25rem 0.4rem !important; /* smaller clickable area */
            font-size: 0.7rem !important;
        }
</style>


<div class="container mt-4" style="min-width:80% !important">
    <div class="card shadow-lg border-0">
        <div class="card shadow-sm">
            <!-- Card Header -->
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" style="background-color:#0099CC !important">
                <h6 class="mb-0"><i class="bi bi-ticket-fill me-2"></i> Ticket Assignment</h6>
                <div class="d-flex align-items-center gap-2">
                    <!-- Show Record -->
                    <div class="d-flex align-items-center me-3">
                        <label class="form-label small mb-0 me-2">Show Record per page</label>
                        <select id="rowsPerPageSelect" class="form-select form-select-sm" style="width: auto;">
                            <option value="10" selected>10</option>
                            <option value="20">20</option>
                            <option value="30">30</option>
                            <option value="40">40</option>
                            <option value="60">60</option>
                            <option value="80">80</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                    <!-- Toggle Filters Button -->
                    <button class="btn btn-light btn-sm d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#filterSection" aria-expanded="false" aria-controls="filterSection">
                        <i class="bi bi-filter me-1"></i> Filters
                    </button>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="card-body py-3" style="background-color:aliceblue">
                <div class="collapse" id="filterSection">
                    <form asp-controller="AsignTicket" asp-action="Index" method="get" class="row g-2 mb-3 align-items-end">

                        <!-- Priority -->
                        <div class="col-md-1">
                            <label class="form-label small">Priority</label>
                            <div class="dropdown">
                                <button class="btn btn-light w-100 text-start dropdown-toggle text-truncate form-control-sm p-1"
                                        type="button" id="priorityDropdown"
                                        data-bs-toggle="dropdown" aria-expanded="false"
                                        style="white-space: nowrap; overflow: hidden; height:15px !important">All
                                </button>

                                <ul class="dropdown-menu p-2" aria-labelledby="priorityDropdown">

                                    @foreach (var p in new[] { "Critical", "High", "Medium", "Low" })
                                    {
                                        <li>
                                            <div class="form-check">
                                                <input class="form-check-input priority-checkbox" type="checkbox" value="@p" id="priority_@p">
                                                <label class="form-check-label" for="priority_@p">@p</label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                                <input type="hidden" name="priority" id="priorityInput" />
                            </div>
                        </div>

                        <!-- Date From -->
                        <div class="col-md-2">
                            <label class="form-label small mb-1">From</label>
                            <div class="input-group input-group-sm" id="dateFromPicker" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                <input type="text" name="dateFrom" class="form-control form-control-sm" data-td-target="#dateFromPicker"
                                       value="@(ViewData["dateFrom"] ?? "")" placeholder="dd-MMM-yyyy" />
                                <span class="input-group-text" data-td-toggle="datetimepicker" data-td-target="#dateFromPicker">
                                    <i class="bi bi-calendar"></i>
                                </span>
                            </div>
                        </div>

                        <!-- Date To -->
                        <div class="col-md-2">
                            <label class="form-label small mb-1">To</label>
                            <div class="input-group input-group-sm" id="dateToPicker" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                <input type="text" name="dateTo" class="form-control form-control-sm" data-td-target="#dateToPicker"
                                       value="@(ViewData["dateTo"] ?? "")" placeholder="dd-MMM-yyyy" />
                                <span class="input-group-text" data-td-toggle="datetimepicker" data-td-target="#dateToPicker">
                                    <i class="bi bi-calendar"></i>
                                </span>
                            </div>
                        </div>

                        <!-- Branch -->
                        <div class="col-md-3">
                            <label class="form-label small">Branch</label>
                            <div class="dropdown">
                                <button class="btn btn-light w-100 text-start dropdown-toggle text-truncate form-control-sm p-1"
                                        type="button" id="branchDropdown"
                                        data-bs-toggle="dropdown" aria-expanded="false"
                                        style="white-space: nowrap; overflow: hidden; height:15px !important">All
                                </button>
                                <ul class="dropdown-menu dropdown-menu-scrollable p-2" aria-labelledby="branchDropdown">
                                    @foreach (var branch in (IEnumerable<ETicketNewUI.Models.ReportTrackingParameterResult>)ViewBag.BranchList)
                                    {
                                        <li>
                                            <div class="form-check">
                                                <input class="form-check-input branch-checkbox" type="checkbox" value="@branch.ID" id="branch_@branch.ID">
                                                <label class="form-check-label" for="branch_@branch.ID">@branch.Name</label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                                <input type="hidden" name="branch" id="branchInput" />
                            </div>
                        </div>

                        <!-- Created By -->
                        <div class="col-md-3">
                            <label class="form-label small">Created By</label>
                            <div class="dropdown">
                                <button class="btn btn-light w-100 text-start dropdown-toggle text-truncate form-control-sm p-1"
                                        type="button" id="createByDropdown"
                                        data-bs-toggle="dropdown" aria-expanded="false"
                                        style="white-space: nowrap; overflow: hidden; height:15px !important">All
                                </button>
                                <ul class="dropdown-menu dropdown-menu-scrollable p-2" aria-labelledby="createByDropdown">
                                    @foreach (var user in (IEnumerable<ETicketNewUI.Models.ReportTrackingParameterResult>)ViewBag.CreateByList)
                                    {
                                        <li>
                                            <div class="form-check">
                                                <input class="form-check-input createby-checkbox" type="checkbox" value="@user.ID" id="createBy_@user.ID">
                                                <label class="form-check-label" for="createBy_@user.ID">@user.Name</label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                                <input type="hidden" name="createBy" id="createByInput" />
                            </div>
                        </div>

                        <div class="col-md-1">
                            <button type="submit" class="btn btn-sm btn-primary w-100">
                                <i class="bi bi-search me-1"></i> Search
                            </button>
                        </div>

                        <!-- Global Search -->
                        <div class="col-md-11 d-flex align-items-end mt-2">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                                <input type="text" id="globalSearch" class="form-control form-control-sm"
                                       placeholder="Find anything in table..." />
                            </div>
                        </div>

                        <!-- Export -->
                        <div class="col-md-1 d-flex align-items-end mt-2">
                            <button type="button" class="btn btn-sm btn-success w-100" id="exportExcel">
                                <i class="bi bi-file-earmark-excel me-1"></i> Export
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>




        <!-- Table -->
        <div class="card-body p-0">
            <div class="table-responsive p-3" id="sessionTableContainer">
                <table class="table table-hover table-sm-font align-middle mb-0" id="sessionTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:4%;">No</th>
                            <th style="width:10%;">Ticket</th>
                            <th style="width:12%;">Branch</th>
                            <th style="width:20%;">Title</th>
                            <th style="width:8%;">Status</th>
                            <th style="width:5%;">Priority</th>
                            <th style="width:8%;">Req.At</th>
                            <th style="width:10%;">RequestBy</th>
                            <th style="width:23%;">PM</th>
                            <th style="width:10%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 1;
                        }
                        @foreach (var session in Model)
                        {
                            <tr data-id="@session.TicketId" data-status="@session.Status">
                                <td data-label="No"><span class="value">@rowIndex</span></td>
                                <td data-label="Ticket"><span class="value">@session.RefID</span></td>
                                <td data-label="Branch"><span class="value">@session.CompanyName</span></td>
                                <td data-label="Title"><span class="value">@session.Title</span></td>
                                <td data-label="Status">
                                    <span class="badge value" style="background-color:@(
                        session.Status == "Request" ? "blue" :
                        session.Status == "Reject" ? "red" :
                        session.Status == "Pending" ? "orange" :
                        session.Status == "Progress" ? "lime" :
                        session.Status == "Done" ? "green" :
                        session.Status == "Feedback" ? "purple" :
                        session.Status == "Update" ? "teal" :
                        session.Status == "Closed" ? "gray" :
                        session.Status == "Cancel" ? "darkred" :
                        "black"
                    ); color:white;">
                                        @session.Status
                                    </span>
                                </td>
                                <td data-label="Priority"><span class="value">@session.Priority</span></td>
                                <td data-label="CreatedDate"><span class="value">@session.CreatedDate</span></td>
                                <td data-label="UserName"><span class="value">@session.UserName</span></td>
                                <td data-label="ProjectManager"><span class="value">@session.ProjectManager</span></td>
                                <td data-label="Action">
                                    <button class="btn btn-sm btn-outline-primary rounded-circle btn-actions" data-id="@session.TicketId" title="Actions">
                                        <i class="bi bi-gear"></i>
                                    </button>
                                </td>
                            </tr>
                            rowIndex++;
                        }
                    </tbody>

                </table>
            </div>

        </div>

        <ul class="pagination" id="tablePagination"></ul>
    </div>

</div>


<!-- Action Popups -->
@foreach (var session in Model)
{
    <div id="popup-@session.TicketId" class="action-popup p-2 shadow rounded bg-white border">
        <ul class="list-unstyled mb-0">
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center @(Model.Any() ? "" : "disabled")"
                   href="@(Model.Any() ? Url.Action("SaveTicketAssign", "AsignTicket", new { id = session.TicketId }) : "#")"
                   style="@(Model.Any() ? "" : "pointer-events:none; opacity:0.5;")">
                    <i class="bi bi-eye me-2 text-primary"></i> View Ticket
                </a>
            </li>
        </ul>
    </div>


}

<div class="toast-container"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // --- Multi-select setup function (safe version) ---
            function setupMultiSelect(dropdownId, checkboxClass, hiddenInputId, allCheckboxId) {
                const dropdownBtn = document.getElementById(dropdownId);
                const hiddenInput = document.getElementById(hiddenInputId);
                const allCheckbox = document.getElementById(allCheckboxId);
                const checkboxes = document.querySelectorAll(`.${checkboxClass}`);

                function updateValue() {
                    let selected = [...checkboxes].filter(cb => cb.checked && cb.value !== "").map(cb => cb.value);
                    if ((allCheckbox && allCheckbox.checked) || selected.length === 0) {
                        hiddenInput.value = "";
                        dropdownBtn.innerText = dropdownBtn.dataset.allText || "All";
                        if (allCheckbox) {
                            checkboxes.forEach(cb => { if (cb !== allCheckbox) cb.checked = false; });
                            allCheckbox.checked = true;
                        }
                    } else {
                        hiddenInput.value = selected.join(",");
                        dropdownBtn.innerText = (selected.length === 1) ? selected[0] : `${selected.length} selected`;
                        if (allCheckbox) allCheckbox.checked = false;
                    }
                }

                const prevValues = hiddenInput.value.split(",");
                checkboxes.forEach(cb => { if (prevValues.includes(cb.value)) cb.checked = true; });
                if (allCheckbox && hiddenInput.value === "") allCheckbox.checked = true;

                checkboxes.forEach(cb => {
                    cb.addEventListener("change", () => {
                        if (allCheckbox && cb === allCheckbox && cb.checked) {
                            checkboxes.forEach(c => { if (c !== cb) c.checked = false; });
                        } else if (allCheckbox) {
                            allCheckbox.checked = false;
                        }
                        updateValue();
                    });
                });

                dropdownBtn.dataset.allText = dropdownBtn.innerText;
                updateValue();
            }

            // Apply to your filters
            setupMultiSelect("priorityDropdown", "priority-checkbox", "priorityInput", "priorityAll");
            setupMultiSelect("branchDropdown", "branch-checkbox", "branchInput", "branchAll");
            setupMultiSelect("createByDropdown", "createby-checkbox", "createByInput", "createByAll");

            // --- Tempus Dominus Datepickers ---
            new tempusDominus.TempusDominus(document.getElementById('dateFromPicker'), {
                display: { components: { calendar: true, clock: false } },
                useCurrent: false,
                localization: { format: 'dd-MMM-yyyy' }
            });
            new tempusDominus.TempusDominus(document.getElementById('dateToPicker'), {
                display: { components: { calendar: true, clock: false } },
                useCurrent: false,
                localization: { format: 'dd-MMM-yyyy' }
            });

            // --- Table & Pagination ---
            let rowsPerPage = parseInt(document.getElementById("rowsPerPageSelect")?.value) || 10;
            const table = document.getElementById("sessionTable");
            const tbody = table?.querySelector("tbody");

            if (tbody) {
                let rows = Array.from(tbody.querySelectorAll("tr"));
                const pagination = document.getElementById("tablePagination");
                let currentPage = 1;
                let filteredRows = [...rows];

                function renderTablePage(page, displayRows = filteredRows) {
                    const totalPages = Math.ceil(displayRows.length / rowsPerPage);
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    rows.forEach(r => r.style.display = "none");
                    displayRows.forEach((r, i) => { if (i >= start && i < end) r.style.display = ""; });
                    if (pagination) renderPagination(page, totalPages, displayRows);
                }

                function renderPagination(page, totalPages, displayRows) {
                    pagination.innerHTML = "";
                    const createPageItem = (label, disabled, callback) => {
                        const li = document.createElement("li");
                        li.className = "page-item" + (disabled ? " disabled" : "");
                        li.innerHTML = `<a class="page-link" href="#">${label}</a>`;
                        li.addEventListener("click", e => { e.preventDefault(); if (!disabled) callback(); });
                        return li;
                    };
                    pagination.appendChild(createPageItem("Previous", page === 1, () => { currentPage--; renderTablePage(currentPage, displayRows); }));
                    for (let i = 1; i <= totalPages; i++) {
                        const li = createPageItem(i, false, () => { currentPage = i; renderTablePage(currentPage, displayRows); });
                        if (i === page) li.classList.add("active");
                        pagination.appendChild(li);
                    }
                    pagination.appendChild(createPageItem("Next", page === totalPages, () => {
                        currentPage++;
                        renderTablePage(currentPage, displayRows);
                    }));
                }

                // --- Global Search ---
                const searchInput = document.getElementById("globalSearch");
                searchInput.addEventListener("input", function () {
                    const keyword = this.value.toLowerCase();
                    filteredRows = rows.filter(r => r.innerText.toLowerCase().includes(keyword));
                    currentPage = 1;
                    renderTablePage(currentPage, filteredRows);
                });

                // --- Rows per page change ---
                const rowsPerPageSelect = document.getElementById("rowsPerPageSelect");
                rowsPerPageSelect.addEventListener("change", function () {
                    rowsPerPage = parseInt(this.value);
                    currentPage = 1;
                    renderTablePage(currentPage, filteredRows);
                });

                renderTablePage(currentPage, filteredRows);
            }

            // --- Export Excel ---
            document.getElementById("exportExcel").addEventListener("click", function () {
                const tableEl = document.getElementById("sessionTable");
                const wb = XLSX.utils.table_to_book(tableEl, { sheet: "Tickets" });
                XLSX.writeFile(wb, `TicketTracking_AllData_${new Date().toISOString().slice(0, 10)}.xlsx`);
            });

            // --- Action Popups ---
            const actionButtons = document.querySelectorAll(".btn-actions");
            actionButtons.forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const id = this.dataset.id;
                    const popup = document.getElementById("popup-" + id);
                    if (popup.style.display === "block") {
                        popup.style.display = "none";
                    } else {
                        document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
                        popup.style.display = "block";
                        const rect = this.getBoundingClientRect();
                        popup.style.position = "absolute";
                        popup.style.top = rect.bottom + window.scrollY + "px";
                        popup.style.left = rect.left + window.scrollX + "px";
                    }
                });
            });

            document.addEventListener("click", function () {
                document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
            });
        });

        // Example functions for popup buttons
        function confirmSession(id) { alert("Confirm ticket: " + id); }
        function followupSession(id) { alert("Followup ticket: " + id); }
        function rejectSession(id) { alert("Reject ticket: " + id); }
    </script>
}


