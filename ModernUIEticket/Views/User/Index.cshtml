@model IEnumerable<ETicketNewUI.Models.userList>
@using System.Globalization

@{
    ViewData["Title"] = "User List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
<link href="~/css/listreport.css" rel="stylesheet" />
<link href="~/css/tableresponsivuser.css" rel="stylesheet" />

<style>
    #tablePagination {
        font-size: 0.7rem !important;
    }

        #tablePagination .page-item {
            margin: 0 2px;
        }

        #tablePagination .page-link {
            padding: 0.25rem 0.4rem !important;
            font-size: 0.7rem !important;
        }

    .action-popup {
        display: none;
        z-index: 1050;
        min-width: 140px;
    }
</style>

<div class="container mt-4" style="min-width:90% !important">
    <div class="card shadow-lg border-0">

        <!-- Filters -->
        <div class="card-body p-3 bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Branch</label>
                    <select id="branchFilter" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var branch in Model.Select(u => u.CompanyName).Distinct())
                        {
                            <option value="@branch">@branch</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Status</label>
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var status in Model.Select(u => u.UStatus).Distinct())
                        {
                            <option value="@status">@((status == "A") ? "Active" : "Inactive")</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label small">Global Search</label>
                    <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Find anything in table..." />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="button" class="btn btn-sm btn-success w-100" id="exportExcel">
                        <i class="bi bi-file-earmark-excel me-1"></i> Export
                    </button>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <a href="@Url.Action("AddUser", "User")" class="btn btn-sm btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i> Create New
                    </a>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card-body p-0">
            <div class="table-responsive p-3" id="userTableContainer">
                <table class="table table-hover table-sm-font align-middle mb-0" id="userTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:4%;">No</th>
                            <th style="width:8%;">User ID</th>
                            <th style="width:12%;">Username</th>
                            <th style="width:12%;">Full Name</th>
                            <th style="width:14%;">Email</th>
                            <th style="width:10%;">Telephone</th>
                            <th style="width:10%;">Company</th>
                            <th style="width:8%;">Status</th>
                            <th style="width:10%;">Created Date</th>
                            <th style="width:10%;">Last Login</th>
                            <th style="width:5%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 1;
                        }
                        @foreach (var user in Model)
                        {
                            <tr data-id="@user.UserId">
                                <td><span>@rowIndex</span></td>
                                <td><span>@user.UserId</span></td>
                                <td><span>@user.UserName</span></td>
                                <td><span>@user.UserFullName</span></td>
                                <td><span>@user.Email</span></td>
                                <td><span>@user.Telephone</span></td>
                                <td><span>@user.CompanyName</span></td>
                                <td>
                                    <span class="badge" style="background-color:@(user.UStatus == "A" ? "green" : "red"); color:white;">
                                        <span>@(user.UStatus == "A" ? "Active" : "Inactive")</span>
                                    </span>
                                </td>
                                <td><span>@user.CreateDate</span></td>
                                <td><span>@user.LastLoginDate</span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary rounded-circle btn-actions"
                                            data-id="@user.UserId"
                                            title="Actions">
                                        <i class="bi bi-gear"></i>
                                    </button>
                                </td>
                            </tr>
                            rowIndex++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <ul class="pagination" id="tablePagination"></ul>
    </div>
</div>

<!-- Action Popups -->
@foreach (var user in Model)
{
    <div id="popup-@user.UserId" class="action-popup p-2 shadow rounded bg-white border">
        <ul class="list-unstyled mb-0">
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                   href="@Url.Action("EditUser", "User", new { userid = user.UserId +user.UserName+ user.CompanyId + user.UserName + user.UserId })">
                    <i class="bi bi-pencil-square me-2 text-primary"></i> Edit
                </a>
            </li>
        </ul>
    </div>
}

<div class="toast-container"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Pagination + Filters + Search
            const rowsPerPage = 10;
            const table = document.getElementById("userTable");
            const tbody = table?.querySelector("tbody");
            if (tbody) {
                let rows = Array.from(tbody.querySelectorAll("tr"));
                const pagination = document.getElementById("tablePagination");
                let currentPage = 1;
                let filteredRows = [...rows];

                function renderTablePage(page, displayRows = filteredRows) {
                    const totalPages = Math.ceil(displayRows.length / rowsPerPage);
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    rows.forEach(r => r.style.display = "none");
                    displayRows.forEach((r, i) => { if (i >= start && i < end) r.style.display = ""; });
                    if (pagination) renderPagination(page, totalPages, displayRows);
                }

                function renderPagination(page, totalPages, displayRows) {
                    pagination.innerHTML = "";

                    const createPageItem = (label, disabled, callback, isActive = false) => {
                        const li = document.createElement("li");
                        li.className = "page-item" + (disabled ? " disabled" : "") + (isActive ? " active" : "");
                        li.innerHTML = `<a class="page-link" href="#">${label}</a>`;
                        li.addEventListener("click", e => { e.preventDefault(); if (!disabled) callback(); });
                        return li;
                    };

                    pagination.appendChild(createPageItem("Previous", page === 1, () => { currentPage--; renderTablePage(currentPage, displayRows); }));

                    const maxVisible = 5;
                    let startPage = Math.max(1, page - Math.floor(maxVisible / 2));
                    let endPage = startPage + maxVisible - 1;
                    if (endPage > totalPages) { endPage = totalPages; startPage = Math.max(1, endPage - maxVisible + 1); }

                    for (let i = startPage; i <= endPage; i++) {
                        pagination.appendChild(createPageItem(i, false, () => { currentPage = i; renderTablePage(currentPage, displayRows); }, i === page));
                    }

                    pagination.appendChild(createPageItem("Next", page === totalPages, () => { currentPage++; renderTablePage(currentPage, displayRows); }));
                }

                function filterRows() {
                    const keyword = document.getElementById("globalSearch").value.toLowerCase();
                    const branchVal = document.getElementById("branchFilter").value.toLowerCase();
                    const statusVal = document.getElementById("statusFilter").value.toLowerCase();

                    filteredRows = rows.filter(r => {
                        const text = r.innerText.toLowerCase();
                        const branch = r.cells[6].innerText.toLowerCase();
                        const status = r.cells[7].innerText.toLowerCase();
                        return text.includes(keyword) && (branchVal === "" || branch.includes(branchVal)) && (statusVal === "" || status.includes(statusVal));
                    });

                    currentPage = 1;
                    renderTablePage(currentPage, filteredRows);
                }

                document.getElementById("globalSearch").addEventListener("input", filterRows);
                document.getElementById("branchFilter").addEventListener("change", filterRows);
                document.getElementById("statusFilter").addEventListener("change", filterRows);

                renderTablePage(currentPage, filteredRows);
            }

            // Export Excel
            document.getElementById("exportExcel").addEventListener("click", function () {
                const tableEl = document.getElementById("userTable");
                const wb = XLSX.utils.table_to_book(tableEl, { sheet: "UserList" });
                XLSX.writeFile(wb, `UserList_${new Date().toISOString().slice(0, 10)}.xlsx`);
            });

            // Action popup
            const actionButtons = document.querySelectorAll(".btn-actions");
            actionButtons.forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const id = this.dataset.id;
                    const popup = document.getElementById("popup-" + id);

                    if (popup.style.display === "block") {
                        popup.style.display = "none";
                    } else {
                        document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
                        popup.style.display = "block";
                        const rect = this.getBoundingClientRect();
                        popup.style.position = "absolute";
                        popup.style.top = rect.bottom + window.scrollY + "px";
                        popup.style.left = rect.left + window.scrollX + "px";
                    }
                });
            });

            // Close popups on click outside or scroll
            document.addEventListener("click", function () {
                document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
            });
            window.addEventListener("scroll", function () {
                document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
            });
        });
    </script>
}

