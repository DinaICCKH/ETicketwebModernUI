@model ETicketNewUI.Models.TicketTrackingDto
@{
    ViewData["Title"] = "Ticket Info";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="~/css/forticketassign.css" rel="stylesheet" />

<div class="container mt-5" style="min-width:100% !important">
    <div class="row">
        <!-- Left Column: Ticket Info -->
        <div class="col-md-5">
            <div class="ticket-card bg-light p-3">
                <h5 class="mb-3"><i class="bi bi-ticket-fill me-2"></i> Ticket Info</h5>
                <dl class="row g-2 ticket-info">
                    <dt class="col-sm-4"><i class="bi bi-hash me-1"></i> Ref ID</dt>
                    <dd class="col-sm-8 text-primary">@Model.RefID</dd>

                    <dt class="col-sm-4"><i class="bi bi-card-text me-1"></i> Title</dt>
                    <dd class="col-sm-8 text-primary">@Model.Title</dd>

                    <dt class="col-sm-4"><i class="bi bi-file-text me-1"></i> Description</dt>
                    <dd class="col-sm-8 text-primary">@Model.Description</dd>

                    <dt class="col-sm-4"><i class="bi bi-person-fill me-1"></i> Created By</dt>
                    <dd class="col-sm-8 text-primary">@Model.CreateByName</dd>

                    <dt class="col-sm-4"><i class="bi bi-geo-alt me-1"></i> Branch</dt>
                    <dd class="col-sm-8 text-primary">@Model.Branch</dd>

                    <dt class="col-sm-4"><i class="bi bi-diagram-3 me-1"></i> Module</dt>
                    <dd class="col-sm-8 text-primary">@Model.Module</dd>

                    <dt class="col-sm-4"><i class="bi bi-flag me-1"></i> Priority</dt>
                    <dd class="col-sm-8 text-primary">@Model.Priority</dd>

                    <dt class="col-sm-4"><i class="bi bi-exclamation-circle me-1"></i> Problem Type</dt>
                    <dd class="col-sm-8 text-primary">@Model.ProblemType</dd>

                    <dt class="col-sm-4"><i class="bi bi-exclamation-triangle me-1"></i> Sub Problem Type</dt>
                    <dd class="col-sm-8 text-primary">@Model.SubProblemType</dd>
                    <dt class="col-sm-4"><i class="bi bi-clipboard-check me-1"></i> Status</dt>
                    <dd class="col-sm-8 text-primary">
                        <span class="ticket-status" style="background-color:@(
                            Model.Status == "Request" ? "blue" :
                            Model.Status == "Reject" ? "red" :
                            Model.Status == "Pending" ? "orange" :
                            Model.Status == "Progress" ? "lime" :
                            Model.Status == "Done" ? "green" :
                            Model.Status == "Feedback" ? "purple" :
                            Model.Status == "Update" ? "teal" :
                            Model.Status == "Closed" ? "gray" :
                            Model.Status == "Cancel" ? "darkred" :
                            "black"
                        );">@Model.Status</span>
                    </dd>
                    <dt class="col-sm-4"><i class="bi bi-paperclip me-1"></i> Attachment</dt>
                    <dd class="col-sm-8 text-primary">
                        @if (!string.IsNullOrEmpty(Model.Attachment))
                        {
                            var ext = System.IO.Path.GetExtension(Model.Attachment).ToLower();
                            var fileName = System.IO.Path.GetFileName(Model.Attachment);

                            if (ext == ".jpg" || ext == ".png" || ext == ".jpeg" || ext == ".gif")
                            {
                                <img src="@Url.Content(Model.Attachment)" alt="Attachment"
                                     style="max-width:100%; height:auto; border-radius:0.25rem; margin-bottom:0.5rem;" />

                                <!-- Download button for image -->
                                <a href="@Url.Content(Model.Attachment)" target="_blank" download class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-download me-1"></i> Download (@fileName)
                                </a>
                            }
                            else
                            {
                                <!-- Download button for non-image -->
                                <a href="@Url.Content(Model.Attachment)" target="_blank" download class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-download me-1"></i> Download (@fileName)
                                </a>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No attachment</span>
                        }
                    </dd>


                </dl>
            </div>
        </div>



        <!-- Right Column: Assignment & Comment -->
        <div class="col-md-7">
            <div class="assign-card bg-white p-3 rounded shadow-sm">

                <!-- Assignment Information -->
                <h5 class="mb-3"><i class="bi bi-person-badge me-2"></i> Assignment Information</h5>
                @if (ViewBag.TicketAssign != null)
                {
                    <div class="mb-4 border p-3 rounded" style="background-color: #f8f9fa;">
                        <div class="mb-2"><strong>Assignment Details:</strong> @ViewBag.TicketAssign.AssignmentDetails</div>
                        <div class="mb-2"><strong>Assigned By:</strong> @ViewBag.TicketAssign.AssignBy</div>
                        <div class="mb-2"><strong>Assign Date:</strong> @((ViewBag.TicketAssign.AssignDate != null) ? Convert.ToDateTime(ViewBag.TicketAssign.AssignDate).ToString("dd-MMM-yyyy HH:mm") : "-")</div>
                        <div class="mb-2"><strong>Deadline Date:</strong> @((ViewBag.TicketAssign.DeadlineDate != null) ? Convert.ToDateTime(ViewBag.TicketAssign.DeadlineDate).ToString("dd-MMM-yyyy HH:mm") : "-")</div>
                        <div class="mb-0"><strong>Remark:</strong> @ViewBag.TicketAssign.Remark</div>
                    </div>
                }
                else
                {
                    <div class="mb-4 text-muted">No assignment information available.</div>
                }

                <!-- Comment Section -->
                <h5 class="mb-3"><i class="bi bi-chat-left-text-fill me-2"></i> Comment</h5>
                <div class="mb-3">
                    <small class="text-danger d-block mt-1 fw-bold">Submit for Accept Task</small>
                    <label class="form-label">Enter your comment</label>
                    <textarea class="form-control form-control-sm" id="commentInput" placeholder="Type your comment here..." rows="4" style="font-size:13px !important;"></textarea>
                </div>

                <div class="row mt-2">
                    <div class="col-3">
                        <button type="button" class="btn btn-success w-100" onclick="acceptTicket(@ViewBag.TicketAssign.AssignID)">
                            <i class="bi bi-check-circle me-1"></i> Accept
                        </button>
                    </div>
                </div>


            </div>
        </div>


    </div>
</div>
<form id="hiddenForm">
    @Html.AntiForgeryToken()
</form>


@section Scripts {
    <script>
        function acceptTicket(ticketId) {
            const commentBox = document.getElementById('commentInput');
            const comment = commentBox.value.trim();

            if (!comment) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Missing Comment',
                    text: 'Please enter a comment before accepting the ticket.'
                });
                return;
            }

            const formData = new FormData();
            formData.append("TicketId", ticketId);
            formData.append("Comment", comment);
            formData.append("__RequestVerificationToken",
                document.querySelector('input[name="__RequestVerificationToken"]').value);

            fetch('@Url.Action("UpdateTicketStatus", "MyTicket")', {
                method: 'POST',
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Ticket Accepted',
                            text: data.message,
                            timer: 3000, // 5 seconds
                            timerProgressBar: true,
                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            willClose: () => {
                                commentBox.value = '';
                                window.location.href = '@Url.Action("Index", "MyTicket")';
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
                            text: data.message,
                            timer: 3000,
                            timerProgressBar: true
                        });
                    }
                })

                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Unexpected Error',
                        text: error.message || 'Something went wrong, please try again.'
                    });
                });
        }
    </script>


}

