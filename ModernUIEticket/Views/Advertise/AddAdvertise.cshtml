@model ETicketNewUI.Models.Advertisement
@{
    ViewData["Title"] = "Create Advertisement";
}

</style>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex align-items-center" style="background-color:#0099CC !important">
                    <i class="bi bi-image me-2" style="font-size: 1.3rem;"></i>
                    <h5 class="mb-0">Create New Advertisement</h5>
                </div>
                <div class="card-body">
                    <form id="advertiseForm" asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- Picture Upload -->
                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-camera me-1"></i> Picture</label>
                            <input asp-for="Picture" type="file" class="form-control form-control-sm" id="fileInput" name="Attachment" accept=".jpg,.jpeg,.png,.gif" />
                            <div class="mt-2" id="filePreview"></div>
                            <div class="mt-1" id="fileDownload" style="display:none;">
                                <a href="#" class="btn btn-outline-secondary btn-sm" download>Download Selected File</a>
                            </div>
                        </div>

                        <!-- Show Picture Status -->
                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-eye me-1"></i> Show Picture</label>
                            <select asp-for="ShowPictureStatus" class="form-select form-select-sm" required>
                                <option value="Y">Yes</option>
                                <option value="N">No</option>
                            </select>
                        </div>

                        <!-- Text Description -->
                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-card-text me-1"></i> Text Description</label>
                            <textarea asp-for="TextDes" class="form-control form-control-sm" rows="3" placeholder="Put your text description here"></textarea>
                        </div>

                        <!-- Show Text Status -->
                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-eye me-1"></i> Show Text</label>
                            <select asp-for="ShowTextDesStatus" class="form-select form-select-sm" required>
                                <option value="Y">Yes</option>
                                <option value="N">No</option>
                            </select>
                        </div>

                        <!-- FromDate & ToDate -->
                        <div class="row mb-3">
                            <div class="col-12 col-md-6 mb-2 mb-md-0">
                                <label class="form-label"><i class="bi bi-calendar-event me-1"></i> From Date</label>
                                <input asp-for="FromDate" type="text" id="FromDate" class="form-control form-control-sm" placeholder="Select From Date" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label"><i class="bi bi-calendar-event me-1"></i> To Date</label>
                                <input asp-for="ToDate" type="text" id="ToDate" class="form-control form-control-sm" placeholder="Select To Date" required />
                            </div>
                        </div>

                  @*       <!-- Status -->
                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-toggle-on me-1"></i> Status</label>
                            <select asp-for="Status" class="form-select form-select-sm" required>
                                <option value="A">Active</option>
                                <option value="I">Inactive</option>
                            </select>
                        </div> *@

                        <!-- Save Button -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-sm text-white fw-semibold" style="background-color: #0099CC;">
                                <i class="bi bi-plus-circle me-1"></i> Save Advertisement
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        flatpickr("#FromDate", {
            dateFormat: "d-M-Y", // dd-MMM-yyyy
            allowInput: true
        });
        flatpickr("#ToDate", {
            dateFormat: "d-M-Y", // dd-MMM-yyyy
            allowInput: true
        });
    </script>
    <script>
        $(document).ready(function () {
            // File Preview
            const fileInput = document.getElementById('fileInput');
            const filePreview = document.getElementById('filePreview');
            const fileDownload = document.getElementById('fileDownload');
            const downloadLink = fileDownload.querySelector('a');

            fileInput.addEventListener('change', function () {
                const file = this.files[0];
                filePreview.innerHTML = '';
                fileDownload.style.display = 'none';

                if (!file) return;

                if (file.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(file);
                    img.style.maxWidth = '200px';
                    img.style.maxHeight = '200px';
                    img.classList.add('img-thumbnail');
                    filePreview.appendChild(img);
                } else {
                    const div = document.createElement('div');
                    div.classList.add('border', 'p-2', 'rounded', 'bg-light');
                    div.textContent = file.name;
                    filePreview.appendChild(div);
                }

                downloadLink.href = URL.createObjectURL(file);
                downloadLink.download = file.name;
                fileDownload.style.display = 'block';
            });

            // AJAX submit
            $("#advertiseForm").submit(function (e) {
                e.preventDefault();
                const formData = new FormData(this);

                $.ajax({
                    url: '@Url.Action("Create", "Advertise")',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        Swal.fire({
                            icon: response.success ? 'success' : 'error',
                            title: response.message,
                            timer: 2000,
                            showConfirmButton: true
                        }).then(() => {
                            if (response.success) location.reload();
                        });
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'Unexpected error occurred.',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    }
                });
            });
        });
    </script>
}
