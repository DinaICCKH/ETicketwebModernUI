@model IEnumerable<ETicketNewUI.Models.TicketAssignListDto>

@using System.Globalization
@{
    ViewData["Title"] = "Ticket Approve";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
<link href="~/css/tableresponsiveticketapproval.css" rel="stylesheet" />
<link href="~/css/listreport.css" rel="stylesheet" />
<style>
    #tablePagination {
        font-size: 0.7rem !important;
    }

        #tablePagination .page-item {
            margin: 0 2px;
        }

        #tablePagination .page-link {
            padding: 0.25rem 0.4rem !important;
            font-size: 0.7rem !important;
        }
</style>

<div class="container mt-4" style="min-width:80% !important">
    <div class="card shadow-lg border-0">
        <div class="card shadow-sm">
            <!-- Card Header -->
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" style="background-color:#0099CC !important">
                <h6 class="mb-0"><i class="bi bi-ticket-fill me-2"></i> Ticket Approval List</h6>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-light btn-sm d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#filterSection" aria-expanded="false" aria-controls="filterSection">
                        <i class="bi bi-filter me-1"></i> Filters
                    </button>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="card-body py-3" style="background-color:aliceblue">
                <div class="collapse" id="filterSection">
                    <form asp-controller="Ticket" asp-action="Index" method="get" class="row g-2 mb-3 align-items-end">
                        <div class="col-md-11 d-flex align-items-end mt-2">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                                <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Find anything in table..." />
                            </div>
                        </div>
                        <div class="col-md-1 d-flex align-items-end mt-2">
                            <button type="button" class="btn btn-sm btn-success w-100" id="exportExcel">
                                <i class="bi bi-file-earmark-excel me-1"></i> Export
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Ticket Table -->
            <div class="table-responsive">
                <table class="table table-striped" id="sessionTable">
                    <thead class="table-light">
                        <tr>
                            <th>No</th>
                            <th>Ticket</th>
                            <th>Branch</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Req.At</th>
                            <th>RequestBy</th>
                            <th>Approver</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 1;
                            foreach (var session in Model)
                            {
                                <tr data-id="@session.TicketId" data-status="@session.Status">
                                    <td>@rowIndex</td>
                                    <td>@session.RefID</td>
                                    <td>@session.CompanyName</td>
                                    <td>@session.Title</td>
                                    <td>
                                        <span class="badge" style="background-color:@(
                                            session.Status == "Request" ? "blue" :
                                            session.Status == "Reject" ? "red" :
                                            session.Status == "Pending" ? "orange" :
                                            session.Status == "Progress" ? "lime" :
                                            session.Status == "Done" ? "green" :
                                            session.Status == "Feedback" ? "purple" :
                                            session.Status == "Update" ? "teal" :
                                            session.Status == "Closed" ? "gray" :
                                            session.Status == "Cancel" ? "darkred" : "black"
                                            ); color:white;">
                                            @session.Status
                                        </span>
                                    </td>
                                    <td>@session.Priority</td>
                                    <td>@session.CreatedDate</td>
                                    <td>@session.UserName</td>
                                    <td>@session.ProjectManager</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary btn-actions" data-id="@session.TicketId">
                                            <i class="bi bi-gear"></i>
                                        </button>
                                    </td>
                                </tr>
                                rowIndex++;
                            }
                        }
                    </tbody>
                </table>
            </div>

            <ul class="pagination" id="tablePagination"></ul>
        </div>
    </div>
</div>

<!-- Action Popups -->
@foreach (var session in Model)
{
    <div id="popup-@session.TicketId" class="action-popup p-2 shadow rounded bg-white border" style="display:none;">
        <ul class="list-unstyled mb-0">
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                   href="@Url.Action("SaveApproveTicket", "Ticket", new { id = session.TicketId })">
                    <i class="bi bi-eye me-2 text-primary"></i> View Ticket
                </a>
            </li>
        </ul>
    </div>
}

<div class="toast-container"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- Table & Pagination ---
            const rowsPerPage = 10;
            const table = document.getElementById("sessionTable");
            const tbody = table?.querySelector("tbody");
            if (tbody) {
                let rows = Array.from(tbody.querySelectorAll("tr"));
                const pagination = document.getElementById("tablePagination");
                let currentPage = 1;
                let filteredRows = [...rows];

                function renderTablePage(page, displayRows = filteredRows) {
                    const totalPages = Math.ceil(displayRows.length / rowsPerPage);
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    rows.forEach(r => r.style.display = "none");
                    displayRows.forEach((r, i) => { if (i >= start && i < end) r.style.display = ""; });
                    if (pagination) renderPagination(page, totalPages, displayRows);
                }

                function renderPagination(page, totalPages, displayRows) {
                    pagination.innerHTML = "";
                    const createPageItem = (label, disabled, callback) => {
                        const li = document.createElement("li");
                        li.className = "page-item" + (disabled ? " disabled" : "");
                        li.innerHTML = `<a class="page-link" href="#">${label}</a>`;
                        li.addEventListener("click", e => { e.preventDefault(); if (!disabled) callback(); });
                        return li;
                    };
                    pagination.appendChild(createPageItem("Previous", page === 1, () => { currentPage--; renderTablePage(currentPage, displayRows); }));
                    for (let i = 1; i <= totalPages; i++) {
                        const li = createPageItem(i, false, () => { currentPage = i; renderTablePage(currentPage, displayRows); });
                        if (i === page) li.classList.add("active");
                        pagination.appendChild(li);
                    }
                    pagination.appendChild(createPageItem("Next", page === totalPages, () => {
                        currentPage++;
                        renderTablePage(currentPage, displayRows);
                    }));
                }

                // --- Global Search ---
                const searchInput = document.getElementById("globalSearch");
                searchInput.addEventListener("input", function () {
                    const keyword = this.value.toLowerCase();
                    filteredRows = rows.filter(r => r.innerText.toLowerCase().includes(keyword));
                    currentPage = 1;
                    renderTablePage(currentPage, filteredRows);
                });

                renderTablePage(currentPage, filteredRows);
            }

            // --- Export Excel ---
            document.getElementById("exportExcel").addEventListener("click", function () {
                const tableEl = document.getElementById("sessionTable");
                const wb = XLSX.utils.table_to_book(tableEl, { sheet: "Tickets" });
                XLSX.writeFile(wb, `TicketTracking_AllData_${new Date().toISOString().slice(0, 10)}.xlsx`);
            });

            // --- Action Popups ---
            const actionButtons = document.querySelectorAll(".btn-actions");
            actionButtons.forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const id = this.dataset.id;
                    const popup = document.getElementById("popup-" + id);
                    if (popup.style.display === "block") {
                        popup.style.display = "none";
                    } else {
                        document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
                        popup.style.display = "block";
                        const rect = this.getBoundingClientRect();
                        popup.style.position = "absolute";
                        popup.style.top = rect.bottom + window.scrollY + "px";
                        popup.style.left = rect.left + window.scrollX + "px";
                    }
                });
            });

            document.addEventListener("click", function () {
                document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
            });
        });
    </script>
}
