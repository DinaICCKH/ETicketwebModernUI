@model ETicketNewUI.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<form id="clientForm" asp-action="EditClient" asp-controller="Client" method="post">
    @Html.AntiForgeryToken()
    <!-- Hidden fields -->
    <input type="hidden" asp-for="SecretCode" />
    <input type="hidden" asp-for="CompanyId" />

    <div class="container mt-4">

        <!-- Client Information -->
        <div class="card shadow-lg border-0">
            <div class="card-header text-white" style="background-color:#0099CC !important">
                <h5 class="mb-0">Edit Client Information</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">

                    <!-- Client Group -->
                    <div class="col-md-4">
                        <label asp-for="ClientGroup" class="form-label"></label>
                        <select asp-for="ClientGroup" class="form-select" asp-items="ViewBag.ClientType">
                            <option value="">-- Select Client Group --</option>
                        </select>
                        <span asp-validation-for="ClientGroup" class="text-danger"></span>
                    </div>

                    <!-- Type (Main/Sub) -->
                    <div class="col-md-2">
                        <label asp-for="CompanyType" class="form-label"></label>
                        <select asp-for="CompanyType" class="form-select" asp-items="ViewBag.CompanyTypeList" id="CompanyType">
                            <option value="">-- Select Type --</option>
                        </select>
                        <span asp-validation-for="CompanyType" class="text-danger"></span>
                    </div>

                    <!-- Main Company -->
                    <div class="col-md-6">
                        <label asp-for="MainCompany" class="form-label"></label>
                        <select asp-for="MainCompany" class="form-select" asp-items="ViewBag.MainCompanyList" id="MainCompanyDropdown">
                            <option value="">-- Select Main Company --</option>
                        </select>
                        <span asp-validation-for="MainCompany" class="text-danger"></span>
                    </div>

                    <!-- Company Name -->
                    <div class="col-md-6">
                        <label asp-for="CompanyName" class="form-label">Company Name</label>
                        <input asp-for="CompanyName" class="form-control" placeholder="Enter company name" />
                    </div>

                    <!-- Short Name -->
                    <div class="col-md-6">
                        <label asp-for="ShortName" class="form-label">Short Name</label>
                        <input asp-for="ShortName" class="form-control" placeholder="Short name" />
                    </div>

                    <!-- Contact Number -->
                    <div class="col-md-3">
                        <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                        <input asp-for="ContactNumber" class="form-control" placeholder="Phone number" />
                    </div>

                    <!-- Contract Number -->
                    <div class="col-md-3">
                        <label asp-for="ContractNo" class="form-label">Contract Number</label>
                        <input asp-for="ContractNo" class="form-control" placeholder="Contract Number" />
                    </div>

                    <!-- Email -->
                    <div class="col-md-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Email address" />
                    </div>

                    <!-- Website -->
                    <div class="col-md-3">
                        <label asp-for="Website" class="form-label">Website</label>
                        <input asp-for="Website" class="form-control" placeholder="Website URL" />
                    </div>

                    <!-- Address -->
                    <div class="col-md-12">
                        <label asp-for="Address1" class="form-label">Address</label>
                        <textarea asp-for="Address1" class="form-control" rows="2" placeholder="Enter address"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dates -->
        <div class="card shadow-lg border-0 mt-4">
            <div class="card-header text-white" style="background-color:#0099CC !important">
                <h5 class="mb-0">Dates</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="JoinDate" class="form-label">Join Date</label>
                        <input asp-for="JoinDate" class="form-control form-control-sm" id="JoinDate" />
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="StartDate" class="form-label">Start Date</label>
                        <input asp-for="StartDate" class="form-control form-control-sm" id="StartDate" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="EndDate" class="form-label">End Date</label>
                        <input asp-for="EndDate" class="form-control form-control-sm" id="EndDate" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="TerminationDate" class="form-label">Termination Date</label>
                        <input asp-for="TerminationDate" class="form-control form-control-sm" id="TerminationDate" />
                        <span asp-validation-for="TerminationDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card shadow-lg border-0 mt-4">
            <div class="card-body d-flex justify-content-end gap-2">

                <!-- Delete Button -->
                <button type="button" id="btnDelete" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete Client
                </button>

                <!-- Update Button -->
                <button type="button" id="btnUpdate" class="btn btn-success">
                    <i class="bi bi-pencil-square"></i> Update Client
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </div>

    </div>
</form>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {

            // Flatpickr setup
            flatpickr("#JoinDate", { dateFormat: "d-M-Y", allowInput: true, defaultDate: "@Model.JoinDate" });
            flatpickr("#StartDate", { dateFormat: "d-M-Y", allowInput: true, defaultDate: "@Model.StartDate" });
            flatpickr("#EndDate", { dateFormat: "d-M-Y", allowInput: true, defaultDate: "@Model.EndDate" });
            flatpickr("#TerminationDate", { dateFormat: "d-M-Y", allowInput: true, defaultDate: "@Model.TerminationDate" });

            // Toggle MainCompany dropdown based on type
            function toggleMainCompany() {
                var type = $('#CompanyType').val();
                if (type === 'Sub') {
                    $('#MainCompanyDropdown').prop('disabled', false);
                } else {
                    $('#MainCompanyDropdown').prop('disabled', true).val('');
                }
            }
            toggleMainCompany();
            $('#CompanyType').change(toggleMainCompany);

            // Update button click (AJAX)
            $("#btnUpdate").click(function (e) {
                e.preventDefault();
                var form = $("#clientForm");

                $.ajax({
                    url: form.attr("action"),
                    type: "POST",
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: "success",
                                title: "Updated",
                                text: response.message,
                                confirmButtonColor: "#0099CC"
                            }).then(() => {
                                window.location.href = '@Url.Action("Index", "Client")';
                            });
                        } else {
                            Swal.fire({
                                icon: "error",
                                title: "Error",
                                text: response.message || "Something went wrong!",
                                confirmButtonColor: "#d33"
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: "error",
                            title: "Server Error",
                            text: "Unexpected error occurred while updating client.",
                            confirmButtonColor: "#d33"
                        });
                    }
                });
            });

            // Delete button click
            $("#btnDelete").click(function (e) {
                e.preventDefault();

                Swal.fire({
                    title: 'Are you sure?',
                    text: "This client will be permanently deleted!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        var form = $("#clientForm");
                        $.ajax({
                            url: '@Url.Action("DeleteClient", "Client")',
                            type: 'POST',
                            data: form.serialize(),
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire({
                                        icon: "success",
                                        title: "Deleted",
                                        text: response.message,
                                        confirmButtonColor: "#0099CC"
                                    }).then(() => {
                                        window.location.href = '@Url.Action("Index", "Client")';
                                    });
                                } else {
                                    Swal.fire({
                                        icon: "error",
                                        title: "Error",
                                        text: response.message || "Something went wrong!",
                                        confirmButtonColor: "#d33"
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: "error",
                                    title: "Server Error",
                                    text: "Unexpected error occurred while deleting client.",
                                    confirmButtonColor: "#d33"
                                });
                            }
                        });
                    }
                });
            });

        });
    </script>
}
