@model IEnumerable<ETicketNewUI.Models.ClientDto>
@using System.Globalization

@{
    ViewData["Title"] = "Client List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
<link href="~/css/listreport.css" rel="stylesheet" />
<link href="~/css/tableresponsivclient.css" rel="stylesheet" />

<style>
    #tablePagination {
        font-size: 0.7rem !important;
    }

        #tablePagination .page-item {
            margin: 0 2px;
        }

        #tablePagination .page-link {
            padding: 0.25rem 0.4rem !important;
            font-size: 0.7rem !important;
        }

    .action-popup {
        display: none;
        z-index: 1050;
        min-width: 140px;
    }
</style>

<div class="container mt-4" style="min-width:90% !important">
    <div class="card shadow-lg border-0">

        <!-- Filters -->
        <div class="card-body p-3 bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Company</label>
                    <select id="companyFilter" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var company in Model.Select(c => c.CompanyName).Distinct())
                        {
                            <option value="@company">@company</option>
                        }
                    </select>
                </div>
                <div class="col-md-7">
                    <label class="form-label small">Global Search</label>
                    <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Find anything in table..." />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="button" class="btn btn-sm btn-success w-100" id="exportExcel">
                        <i class="bi bi-file-earmark-excel me-1"></i> Export
                    </button>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <a href="@Url.Action("AddClient", "Client")" class="btn btn-sm btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i> New
                    </a>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card-body p-0">
            <div class="table-responsive p-3" id="clientTableContainer">
                <table class="table table-hover table-sm-font align-middle mb-0" id="clientTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:4%;">No</th>
                            <th style="width:10%;">Company ID</th>
                            <th style="width:29%;">Company Name</th>
                            <th style="width:10%;">Short Name</th>
                            <th style="width:15%;">Contact</th>
                            <th style="width:15%;">Email</th>
                            <th style="width:8%;">Status</th>
                            <th style="width:15%;">Join Date</th>
                            <th style="width:10%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 1;
                        }
                        @foreach (var client in Model)
                        {
                            <tr data-id="@client.CompanyId">
                                <td>@rowIndex</td>
                                <td>@client.CompanyId</td>
                                <td>@client.CompanyName</td>
                                <td>@client.ShortName</td>
                                <td>@client.ContactNumber</td>
                                <td>@client.Email</td>
                                <td>
                                    <span class="badge" style="background-color:@(client.Active == "A" ? "green" : "red"); color:white;">
                                        @(client.Active == "A" ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>@client.JoinDate</td>
                            
                                <td>
                                    <button class="btn btn-sm btn-outline-primary rounded-circle btn-actions"
                                            data-id="@client.CompanyId" title="Actions">
                                        <i class="bi bi-gear"></i>
                                    </button>
                                </td>
                            </tr>
                            rowIndex++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <ul class="pagination" id="tablePagination"></ul>
    </div>
</div>

<!-- Action Popups -->
@foreach (var client in Model)
{
    <div id="popup-@client.CompanyId" class="action-popup p-2 shadow rounded bg-white border">
        <ul class="list-unstyled mb-0">
            <li class="mb-1">
                <a class="btn btn-sm btn-light w-100 text-start d-flex align-items-center"
                   href="@Url.Action("EditClient", "Client", new { companyId = client.CompanyId })">
                    <i class="bi bi-pencil-square me-2 text-primary"></i> Edit
                </a>
            </li>
        </ul>
    </div>
}

<div class="toast-container"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rowsPerPage = 10;
            const table = document.getElementById("clientTable");
            const tbody = table?.querySelector("tbody");
            if (!tbody) return;
            let rows = Array.from(tbody.querySelectorAll("tr"));
            let filteredRows = [...rows];
            let currentPage = 1;
            const pagination = document.getElementById("tablePagination");

            function renderTablePage(page, displayRows = filteredRows) {
                const totalPages = Math.ceil(displayRows.length / rowsPerPage);
                const start = (page - 1) * rowsPerPage;
                const end = start + rowsPerPage;
                rows.forEach(r => r.style.display = "none");
                displayRows.forEach((r, i) => { if (i >= start && i < end) r.style.display = ""; });
                renderPagination(page, totalPages, displayRows);
            }

            function renderPagination(page, totalPages, displayRows) {
                pagination.innerHTML = "";
                const createPageItem = (label, disabled, callback, isActive = false) => {
                    const li = document.createElement("li");
                    li.className = "page-item" + (disabled ? " disabled" : "") + (isActive ? " active" : "");
                    li.innerHTML = `<a class="page-link" href="#">${label}</a>`;
                    li.addEventListener("click", e => { e.preventDefault(); if (!disabled) callback(); });
                    return li;
                };
                pagination.appendChild(createPageItem("Previous", page === 1, () => { currentPage--; renderTablePage(currentPage, displayRows); }));
                const maxVisible = 5;
                let startPage = Math.max(1, page - Math.floor(maxVisible / 2));
                let endPage = startPage + maxVisible - 1;
                if (endPage > totalPages) { endPage = totalPages; startPage = Math.max(1, endPage - maxVisible + 1); }
                for (let i = startPage; i <= endPage; i++) {
                    pagination.appendChild(createPageItem(i, false, () => { currentPage = i; renderTablePage(currentPage, displayRows); }, i === page));
                }
                pagination.appendChild(createPageItem("Next", page === totalPages, () => { currentPage++; renderTablePage(currentPage, displayRows); }));
            }

            function filterRows() {
                const keyword = document.getElementById("globalSearch").value.toLowerCase();
                const companyVal = document.getElementById("companyFilter").value.toLowerCase();
                filteredRows = rows.filter(r => {
                    const text = r.innerText.toLowerCase();
                    const company = r.cells[2].innerText.toLowerCase();
                    return text.includes(keyword) && (companyVal === "" || company.includes(companyVal));
                });
                currentPage = 1;
                renderTablePage(currentPage, filteredRows);
            }

            document.getElementById("globalSearch").addEventListener("input", filterRows);
            document.getElementById("companyFilter").addEventListener("change", filterRows);

            renderTablePage(currentPage, filteredRows);

            // Export Excel
            document.getElementById("exportExcel").addEventListener("click", function () {
                const wb = XLSX.utils.table_to_book(table, { sheet: "ClientList" });
                XLSX.writeFile(wb, `ClientList_${new Date().toISOString().slice(0, 10)}.xlsx`);
            });

            // Action popups
            document.querySelectorAll(".btn-actions").forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const id = this.dataset.id;
                    const popup = document.getElementById("popup-" + id);
                    if (popup.style.display === "block") { popup.style.display = "none"; }
                    else {
                        document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none");
                        popup.style.display = "block";
                        const rect = this.getBoundingClientRect();
                        popup.style.position = "absolute";
                        popup.style.top = rect.bottom + window.scrollY + "px";
                        popup.style.left = rect.left + window.scrollX + "px";
                    }
                });
            });

            document.addEventListener("click", () => document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none"));
            window.addEventListener("scroll", () => document.querySelectorAll(".action-popup").forEach(p => p.style.display = "none"));
        });
    </script>
}
