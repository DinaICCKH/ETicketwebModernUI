@using Newtonsoft.Json
@using System.Text
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var tokenData = (LoginResultDto)null;
    var tokenBase64 = HttpContextAccessor.HttpContext.Session.GetString("UserToken");

    if (!string.IsNullOrEmpty(tokenBase64))
    {
        try
        {
            var tokenJson = Encoding.UTF8.GetString(Convert.FromBase64String(tokenBase64));
            tokenData = JsonConvert.DeserializeObject<LoginResultDto>(tokenJson);
        }
        catch { }
    }
}

