                                (tokenData.Type != null && tokenData.Type.ToString() == "Client" && tokenData.FullAuthorization?.ToString() == "Y") ||
                                (tokenData.Type != null && tokenData.Type.ToString() == "Moderator" && tokenData.FullAuthorization?.ToString() == "N") ||
                                (tokenData.FullAuthorization?.ToString() == "Y" && tokenData.Type?.ToString() != "Client") ||
                                (tokenData.Type?.ToString() == "Admin" || tokenData.Type?.ToString() == "Manager");
                        }

                        @if (showApprovalLink)
                        {
                            <li class="nav-item ms-3">
                                <a class="nav-link position-relative" href="@Url.Action("ApproveTicket", "Ticket")" title="Approval">
                                    <i class="bi bi-check2-square" style="font-size: 1.3rem;"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="approvalCount">
                                        0
                                        <span class="visually-hidden">pending approvals</span>
                                    </span>
                                </a>
                            </li>
                        }


                        

                       <!-- Notification Icon -->
                        <li class="nav-item dropdown ms-3">
                            <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell" style="font-size: 1.2rem;"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notifCount">
                                    0
                                    <span class="visually-hidden">unread messages</span>
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end p-0" aria-labelledby="notificationDropdown" style="min-width: 300px; max-height: 400px; overflow-y: auto;" id="notifList">
                                <li class="dropdown-header bg-light text-center fw-bold">Notifications</li>
                                <!-- Alerts will be appended here dynamically -->
                            </ul>
                        </li>



                        <li class="nav-item dropdown ms-3">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-2" style="font-size: 1.4rem;"></i>
                                @if (tokenData != null)
                                {
                                    <span class="fw-semibold">@tokenData.UserName</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                <!-- Profile section -->
                                <li class="px-3 py-2 text-center">
                                    <i class="bi bi-person-circle mb-2" style="font-size: 2.5rem; color:#6c757d;"></i>
                                    <div class="fw-bold">@tokenData?.UserName</div>
                                    <div class="text-muted small">@tokenData?.CompanyName</div>
                                </li>
                                <li><hr class="dropdown-divider"></li>

                                <!-- Menu items -->
                                <li><a class="dropdown-item" href="javascript:void(0);" onclick="toggleTheme()"><i class="bi bi-moon-stars me-2"></i> Toggle Theme</a></li>
                                <li class="dropdown-item px-3 py-2">
                                    <div id="google_translate_element"></div>
                                </li>

                                <li><hr class="dropdown-divider"></li>
                                <li><a href="javascript:void(0);" class="dropdown-item text-danger" onclick="confirmLogout()"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                            </ul>
                        </li>


                    </ul>
                </div>
            </div>
        </nav>
    </header>


    <!-- 90% Width Content Wrapper -->
    <div class="main-wrapper mt-4" style="min-width: 90% !important; margin: 0 auto;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script>
        // ---------------- Approval Count ----------------
        async function loadApprovalCount() {
            try {
                const response = await fetch('/Ticket/ApproveTicket?isCountOnly=true');
                const data = await response.json();

                const badge = document.getElementById("approvalCount");
                if (badge) {
                    badge.innerText = data.count || 0; // fallback to 0 if undefined
                }
            } catch (error) {
                console.error("Failed to load approval count:", error);
            }
        }

        // ---------------- Notifications ----------------
        async function loadNotifications() {
            try {
                const response = await fetch('/Ticket/GetAlerts');
                const result = await response.json();

                if (!result.success) return;

                const alerts = result.data || [];
                const notifList = document.getElementById("notifList");
                const notifCount = document.getElementById("notifCount");

                // Header with "Read All"
                notifList.innerHTML = `
                    <li class="dropdown-header bg-light text-center fw-bold d-flex justify-content-between align-items-center">
                        Notifications
                        <button class="btn btn-sm btn-link p-0" onclick="readAllAlerts()">Read All</button>
                    </li>
                `;

                // Update badge count
                notifCount.innerText = alerts.length;

                // If no alerts
                if (alerts.length === 0) {
                    notifList.innerHTML += `
                        <li class="dropdown-item text-center text-muted small">
                            No new notifications
                        </li>
                    `;
                    return;
                }

                // Populate alerts
                alerts.forEach(alert => {
                    const li = document.createElement('li');
                    li.classList.add('alert-item');
                    li.innerHTML = `
                        <a class="dropdown-item d-flex justify-content-between align-items-start" href="#"
                           onclick="event.preventDefault(); readAlert('${alert.id}', '${alert.link}')">
                            <div>
                                <div class="fw-bold">${alert.type}</div>
                                <div class="small" style="max-width: 350px; white-space: normal;" title="${alert.description}">
                                    ${alert.description}
                                </div>
                            </div>
                            <div class="text-muted small ms-2">${alert.createdDateTime}</div>
                        </a>
                    `;
                    notifList.appendChild(li);
                });
            } catch (error) {
                console.error("Failed to load notifications:", error);
            }
        }

        // ---------------- Mark single alert as read ----------------
        async function readAlert(alertId, redirectUrl) {
            try {
                await fetch('/Ticket/MarkAlertRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${alertId}`
                });

                // Redirect after marking as read
                window.location.href = redirectUrl;
            } catch (error) {
                console.error("Failed to mark alert read:", error);
            }
        }

        // ---------------- Mark all alerts as read ----------------
        async function readAllAlerts() {
            try {
                await fetch('/Ticket/MarkAllAlertsRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
                });

                // Refresh notifications
                loadNotifications();
            } catch (error) {
                console.error("Failed to mark all alerts read:", error);
            }
        }

        // ---------------- Init ----------------
        document.addEventListener("DOMContentLoaded", () => {
            loadApprovalCount();
            loadNotifications();
        });

        // Refresh every 30s
        setInterval(() => {
            loadApprovalCount();
            loadNotifications();
        }, 30000);
    </script>

    <script type="text/javascript">
        // Initialize Google Translate
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'km,zh-CN,ko,th,id,lo,fr,de',
                layout: google.translate.TranslateElement.InlineLayout.SIMPLE
            }, 'google_translate_element');
        }

        // Hide the top Google translate bar
        function hideGoogleTopBar() {
            const banner = document.querySelector('.goog-te-banner-frame.skiptranslate');
            if (banner) banner.style.display = 'none';
            document.body.style.top = '0px';
        }

        // Observe DOM changes to remove top bar dynamically
        const observer = new MutationObserver(hideGoogleTopBar);
        observer.observe(document.body, { childList: true, subtree: true });

        // Hide immediately if already loaded
        hideGoogleTopBar();
    </script>
    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <!-- jQuery, Bootstrap & site scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script type="text/javascript">
        // Theme handling
        function applyTheme(theme) {
            document.body.classList.toggle('dark-mode', theme === 'dark');
            document.querySelectorAll('.login-card').forEach(el => el.classList.toggle('dark-mode', theme === 'dark'));
        }

        function toggleTheme() {
            const currentTheme = localStorage.getItem('theme') || 'light';
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            localStorage.setItem('theme', newTheme);
            applyTheme(newTheme);
        }

        // Language handling
        function applyLanguage(lang) {
            document.documentElement.setAttribute('data-lang', lang);
            localStorage.setItem('language', lang);
        }

        function switchLanguage(newLang) {
            applyLanguage(newLang);
        }

        // Apply saved preferences on page load
        document.addEventListener('DOMContentLoaded', function () {
            applyTheme(localStorage.getItem('theme') || 'light');
            applyLanguage(localStorage.getItem('language') || 'kh');
        });

        // Logout confirmation
        function confirmLogout() {
            Swal.fire({
                title: 'Are you sure?',
                text: "You will be logged out!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, logout!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Login/Logout';
                }
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
