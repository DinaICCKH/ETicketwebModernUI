@model ETicketNewUI.Models.ApprovalHeader
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Edit Approval Setup";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="~/css/forticketassign.css" rel="stylesheet" />

<style>
    /* Make overall page font smaller */
    body {
        font-size: 13px !important;
    }

    /* Smaller card header */
    .card h5 {
        font-size: 13px !important;
    }

    /* Smaller labels */
    .form-label-sm,
    .col-form-label {
        font-size: 13px !important;
    }

    /* Smaller selects & inputs */
    .form-control-sm,
    .form-select-sm,
    textarea.form-control-sm {
        font-size: 13px !important;
        padding: 2px 4px !important;
    }

    /* Smaller table text */
    #stageTable th,
    #stageTable td {
        font-size: 13px !important;
        padding: 2px 4px !important;
    }

    /* Smaller buttons */
    .btn-sm {
        font-size: 11px !important;
        padding: 2px 6px !important;
    }

    /* Smaller SweetAlert text */
    .swal2-popup {
        font-size: 13px !important;
    }

</style>

@Html.AntiForgeryToken()

<div class="container mt-5" style="min-width:100% !important">
    <div class="row">
        <div class="col-md-12">
            <div class="ticket-card bg-light p-3">
                <h5 class="mb-3"><i class="bi bi-check2-circle me-2"></i> Edit Approval Setup</h5>
                <dl class="row g-2 ticket-info">
                    <!-- Company + Status -->
                    <dt class="col-sm-4"><i class="bi bi-building me-1"></i> Company</dt>
                    <dd class="col-sm-8 text-primary d-flex gap-2 align-items-center">
                        <!-- Company Select -->
                        <select class="form-select form-select-sm flex-grow-1" id="companySelect" disabled>
                            <option value="">-- Select Company --</option>
                            @foreach (var company in (IEnumerable<ETicketNewUI.Models.ProjectAvailable>)ViewBag.MainCompany)
                            {
                                if (company.CompanyId == Model.CompanyId)
                                {
                                    <option value="@company.CompanyId" selected>
                                        @company.CompanyName (@company.ShortName)
                                    </option>
                                }
                                else
                                {
                                    <option value="@company.CompanyId">
                                        @company.CompanyName (@company.ShortName)
                                    </option>
                                }
                            }
                        </select>

                        <select class="form-select form-select-sm" id="companyStatusSelect">
                            <option value="A" selected="@(Model.Status == "A" ? "selected" : null)">Active</option>
                            <option value="I" selected="@(Model.Status == "I" ? "selected" : null)">Inactive</option>
                        </select>

                    </dd>
                    <div class="form-text small text-muted">
                        Choose company to load available approvers and branches, and select status.
                    </div>

                    <!-- Remark -->
                    <dt class="col-sm-4"><i class="bi bi-card-text me-1"></i> Remark</dt>
                    <dd class="col-sm-8 text-primary">
                        <textarea class="form-control form-control-sm" id="remarkInput" rows="2">@Model.Remark</textarea>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Approvers Table -->
    <div class="row mt-3">
        <div class="col-md-12">
            <div class="assign-card bg-white p-3 rounded shadow-sm">
                <h5 class="mb-3"><i class="bi bi-people-fill me-2"></i> Approvers</h5>

                <div class="mb-3 d-flex gap-2">
                    <select class="form-select form-select-sm flex-grow-1" id="userSelect">
                        <option value="">-- Choose Approver --</option>
                    </select>
                    <button id="clearAllBtn" class="btn btn-sm btn-outline-danger" type="button">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>

                <table class="table table-bordered table-sm mt-2" id="approvalTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:4%">#</th>
                            <th style="width:25%">Approver</th>
                            <th style="width:20%">Branch</th>
                            <th style="width:12%">From</th>
                            <th style="width:12%">To</th>
                            <th style="width:20%">Remark</th>
                            <th style="width:7%">Status</th>
                            <th style="width:6%">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <div class="row mt-3 align-items-center gx-2">
                    <div class="col-auto">
                        <button type="button" class="btn btn-primary" onclick="submitApproval()">
                            <i class="bi bi-check-circle me-1"></i> Save
                        </button>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-danger" id="deleteApprovalBtn">
                            <i class="bi bi-trash me-1"></i> Delete
                        </button>
                    </div>

                    <div class="col-auto">
                        <span id="rowCount" class="text-muted">0 rows</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

@section Scripts {
    <script>
        let subBranches = [];
        let userAssignList = [];


        // --- Delete Approval ---
        document.getElementById('deleteApprovalBtn').addEventListener('click', () => {
            Swal.fire({
                icon: 'warning',
                title: 'Confirm Delete',
                text: 'Are you sure you want to delete this approval?',
                showCancelButton: true,
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (!result.isConfirmed) return;

                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const modelId = '@Model.ID';

                // Payload for Delete
                const payload = {
                    ID: modelId,
                    Mode: 'Delete',
                    RowList: [] // optional, backend already handles
                };

                fetch('@Url.Action("DeleteApproval", "Approval")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Deleted',
                                text: data.message,
                                timer: 3000,
                                timerProgressBar: true,
                                willClose: () => window.location.href = '@Url.Action("Index", "Approval")'
                            });
                        } else {
                            Swal.fire('Error', data.message || 'Failed to delete', 'error');
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        Swal.fire('Error', 'Unexpected error while deleting approval.', 'error');
                    });
            });
        });


        $(document).ready(async function () {
            const token = $('input[name="__RequestVerificationToken"]').val();
            const companySelect = document.getElementById('companySelect');
            const userSelect = document.getElementById('userSelect');
            const tableBody = document.querySelector('#approvalTable tbody');
            const modelId = '@Model.ID';
            const existingRows = @Html.Raw(JsonConvert.SerializeObject(ViewBag.RowLists ?? new List<ETicketNewUI.Models.ApprovalDetail>()));

            const companyId = companySelect.value;
            if (!companyId) {
                console.log("⚠️ No company selected.");
                return;
            }

            try {
                // --- Load Branches ---
                const branchRes = await fetch('@Url.Action("GetBranches", "Approval")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: new URLSearchParams({ companyId }).toString()
                });
                subBranches = await branchRes.json();

                // --- Load Approvers ---
                const userRes = await fetch('@Url.Action("GetUserAssign", "Approval")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: new URLSearchParams({ companyId }).toString()
                });
                userAssignList = await userRes.json();

                // --- Populate Approver Dropdown ---
                userAssignList.forEach(u => {
                    const option = document.createElement('option');
                    option.value = u.id;
                    option.textContent = u.fullStaffName;
                    userSelect.appendChild(option);
                });

                // --- Load existing approval rows ---
                if (existingRows.length) {
                    existingRows.forEach(r => {
                        addApprovalRow(r.UserId, r.FullStaffName, r.SubcompanyId, r.FromDate, r.ToDate, r.Remark, r.Status);
                    });
                }
            } catch (err) {
                console.error('❌ Auto-load Fetch Error:', err);
                Swal.fire('Error', 'Failed to auto-load branches or approvers.', 'error');
            }



            // --- Add approver row when user selected ---
            userSelect.addEventListener('change', () => {
                const staffId = userSelect.value;
                const staffName = userSelect.selectedOptions[0]?.text;
                if (!staffId) return;
                addApprovalRow(staffId, staffName);
                userSelect.value = '';
            });

            // --- Clear all rows ---
            document.getElementById('clearAllBtn').addEventListener('click', () => {
                tableBody.innerHTML = '';
                reindexRows();
            });

            // --- Build branch dropdown options ---
            function buildBranchOptions(selected = '') {
                if (!subBranches.length) return '<option value="">-- No branch --</option>';
                return subBranches.map(b => {
                    const selectedAttr = selected.toString() === b.companyId.toString() ? 'selected' : '';
                    return `<option value="${b.companyId}" ${selectedAttr}>${b.companyName}</option>`;
                }).join('');
            }

            // --- Convert date string to JS Date ---
            function parseDate(dateStr) {
                if (!dateStr) return null;
                if (!isNaN(Date.parse(dateStr))) return new Date(dateStr);
                const parts = dateStr.split('/');
                if (parts.length === 3) return new Date(`${parts[2]}-${parts[1]}-${parts[0]}`);
                return null;
            }

            // --- Add row to table ---

            function addApprovalRow(staffId, staffName, selectedBranchId = '', fromDate = '', toDate = '', remark = '', status = 'A') {
                const tr = document.createElement('tr');
                tr.dataset.staffId = staffId;

                // Build row HTML first with empty branch & status
                tr.innerHTML = `
                <td class="rowIndex text-center"></td>
                <td>
                    ${staffName}
                    <input type="hidden" class="staffIdInput" value="${staffId}" />
                </td>
                <td>
                    <select class="form-select form-select-sm branchSelect"></select>
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm fromDateInput" placeholder="Select date" />
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm toDateInput" placeholder="Select date" />
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm remarkInput" placeholder="Enter remark" />
                </td>
                <td>
                    <select class="form-select form-select-sm statusSelect">
                        <option value="A">Active</option>
                        <option value="I">Inactive</option>
                    </select>
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-danger removeRowBtn">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </td>
            `;

                tableBody.appendChild(tr);

                // --- Populate branch options for this row ---
                const branchSelect = tr.querySelector('.branchSelect');
                branchSelect.innerHTML = subBranches.map(b => {
                    const selectedAttr = selectedBranchId == b.companyId ? 'selected' : '';
                    return `<option value="${b.companyId}" ${selectedAttr}>${b.companyName}</option>`;
                }).join('');

                // --- Populate status for this row ---
                const statusSelect = tr.querySelector('.statusSelect');
                statusSelect.value = status;

                // --- Populate remark ---
                tr.querySelector('.remarkInput').value = remark;

                // --- Initialize Flatpickr per row ---
                flatpickr(tr.querySelector(".fromDateInput"), {
                    dateFormat: "d-M-Y",
                    allowInput: true,
                    defaultDate: parseDate(fromDate)
                });
                flatpickr(tr.querySelector(".toDateInput"), {
                    dateFormat: "d-M-Y",
                    allowInput: true,
                    defaultDate: parseDate(toDate)
                });

                // --- Remove row ---
                tr.querySelector('.removeRowBtn').addEventListener('click', () => {
                    tr.remove();
                    reindexRows();
                });

                reindexRows();
            }


            // --- Reindex rows ---
            function reindexRows() {
                document.querySelectorAll('#approvalTable tbody tr').forEach((r, i) => {
                    r.querySelector('.rowIndex').innerText = i + 1;
                });
                document.getElementById('rowCount').innerText =
                    `${document.querySelectorAll('#approvalTable tbody tr').length} row(s)`;
            }
        });

        // --- Submit Approval ---
        function submitApproval() {
            const rows = Array.from(document.querySelectorAll('#approvalTable tbody tr'));

            if (!rows.length) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Warning',
                    text: 'Please add at least one approver.',
                    customClass: { popup: 'swal-small-text' }
                });
                return;
            }

            const companyId = parseInt(document.getElementById('companySelect').value || 0);
            const remarkHeader = document.getElementById('remarkInput').value || '';
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const modelId = '@Model.ID';
            const companyStatus = document.getElementById('companyStatusSelect').value;

            if (!companyId) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation',
                    text: 'Please select a Company.',
                    customClass: { popup: 'swal-small-text' }
                });
                return;
            }

            let rowList = [];

            try {
                rowList = rows.map((r, i) => {
                    const staffId = parseInt(r.querySelector('.staffIdInput')?.value || 0);
                    const subCompanyId = parseInt(r.querySelector('.branchSelect')?.value || 0);

                    const fromDateObj = r.querySelector('.fromDateInput')?._flatpickr?.selectedDates[0] || null;
                    const toDateObj = r.querySelector('.toDateInput')?._flatpickr?.selectedDates[0] || null;

                    const remark = r.querySelector('.remarkInput')?.value || '';
                    const status = r.querySelector('.statusSelect')?.value || 'A';

                    if (!staffId) {
                        throw new Error(`Row ${i + 1}: Staff is required`);
                    }

                    return {
                        ID: null,
                        LineNum: i + 1,
                        UserId: staffId,
                        SubcompanyId: subCompanyId,
                        Status: status,
                        FromDate: toIsoNoTimezone(fromDateObj),
                        ToDate: toIsoNoTimezone(toDateObj),
                        Remark: remark
                    };
                });
            } catch (err) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation',
                    text: err.message || 'Error reading row data',
                    customClass: { popup: 'swal-small-text' }
                });
                return;
            }

            const payload = {
                Mode: 'Update',
                ID: modelId,
                CompanyId: companyId,
                UpdateBy: '@User?.Identity?.Name',
                UpdateDate: new Date().toISOString(),
                Status: companyStatus,
                Remark: remarkHeader,
                RowList: rowList
            };

            console.log(payload);

            fetch('@Url.Action("EditApproval", "Approval")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: data.message,
                            timer: 15000,
                            timerProgressBar: true,
                            customClass: { popup: 'swal-small-text' },
                            willClose: () => {
                                window.location.href = '@Url.Action("Index", "Approval")';
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message || 'Update failed',
                            customClass: { popup: 'swal-small-text' }
                        });
                    }
                })
                .catch(err => {
                    console.error(err);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Unexpected error while updating approval.',
                        customClass: { popup: 'swal-small-text' }
                    });
                });
        }

        // --- Convert Date to ISO without timezone ---
        function toIsoNoTimezone(date) {
            if (!date) return null;

            const yyyy = date.getFullYear();
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');

            return `${yyyy}-${mm}-${dd}T00:00:00`;
        }
    </script>
}




